<% diff = @tentativas_semana.count - @tentativas_semana_passada.count %>
<% tentativas_recentes = Current.user.tentativas.order(concluida_em: :desc).limit(4) %>
<% missoes_semana = @tentativas_semana.count %>
<% dias_seguidos = Current.user.sequencia_dias %>
<% progresso_xp = xp_percentual(Current.user) %>
<% total_missoes = Current.user.tentativas.count %>
<% xp_por_dia = @xp_por_dia.map.with_index do |(label, valor), _i|
     data_label = label.respond_to?(:strftime) ? label.strftime('%d/%m') : label.to_s
     { label: data_label, valor: valor.to_i }
   end %>
<% missoes_por_semana = @missoes_por_semana.map.with_index do |(label, valor), _i|
     semana_label = label.respond_to?(:strftime) ? label.strftime('%d/%m') : label.to_s
     { label: semana_label, valor: valor.to_i }
   end %>

<div class="bg-app min-h-screen pb-28">
  <div class="px-4 pt-8 space-y-4">

    <%# ── HEADER ── %>
    <div style="background: linear-gradient(170deg, var(--action-primary) 0%, var(--action-primary-strong) 100%); border-radius: 24px; padding: 22px 20px;">
      <div style="display: flex; align-items: flex-start; justify-content: space-between; gap: 12px;">
        <div>
          <p style="font-size: 11px; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: color-mix(in srgb, var(--text-on-accent) 75%, transparent);">Meu histórico</p>
          <h1 style="font-size: 22px; font-weight: 600; color: var(--text-on-accent); margin-top: 6px; line-height: 1.3;">Olá, <%= Current.user.name.split.first %>!</h1>
          <p style="font-size: 14px; color: color-mix(in srgb, var(--text-on-accent) 82%, transparent); margin-top: 4px; line-height: 1.5;">Seu ritmo, conquistas e evolução nas missões.</p>
        </div>
        <div style="width: 52px; height: 52px; border-radius: 50%; background: color-mix(in srgb, var(--text-on-accent) 15%, transparent); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
          <i class="fa-solid fa-chart-line" style="font-size: 20px; color: var(--text-on-accent);" aria-hidden="true"></i>
        </div>
      </div>

      <div style="background: color-mix(in srgb, var(--text-on-accent) 14%, transparent); border-radius: 16px; padding: 14px 16px; margin-top: 14px;">
        <div style="display: flex; align-items: center; justify-content: space-between; gap: 8px;">
          <div>
            <p style="font-size: 13px; color: color-mix(in srgb, var(--text-on-accent) 78%, transparent);">Nível atual</p>
            <p style="font-size: 15px; font-weight: 600; color: var(--text-on-accent); margin-top: 2px;">Nível <%= Current.user.nivel %> · <%= nivel_nome(Current.user.nivel) %></p>
          </div>
          <span style="background: color-mix(in srgb, var(--text-on-accent) 18%, transparent); border-radius: 999px; padding: 7px 16px; font-size: 13px; font-weight: 600; color: var(--text-on-accent); white-space: nowrap;"><%= Current.user.xp_total %> XP</span>
        </div>
        <div style="display: flex; justify-content: space-between; font-size: 12px; color: color-mix(in srgb, var(--text-on-accent) 78%, transparent); margin: 12px 0 6px;">
          <span>Progresso para o próximo nível</span>
          <span><%= progresso_xp %>%</span>
        </div>
        <div style="height: 8px; background: color-mix(in srgb, var(--text-on-accent) 20%, transparent); border-radius: 999px; overflow: hidden;">
          <div style="height: 100%; background: var(--text-on-accent); border-radius: 999px; width: <%= progresso_xp %>%; transition: width 0.6s ease;"></div>
        </div>
      </div>
    </div>

    <%# ── GRID DE ESTATÍSTICAS ── %>
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 10px;">
      <div style="background: var(--surface-bg); border-radius: 18px; border: 1px solid var(--border-subtle); padding: 16px 14px 14px; box-shadow: var(--shadow-soft);">
        <i class="fa-solid fa-bolt" style="font-size: 20px; color: var(--action-primary);" aria-hidden="true"></i>
        <p style="font-size: 26px; font-weight: 600; color: var(--text-primary); margin-top: 10px; line-height: 1;"><%= dias_seguidos %></p>
        <p style="font-size: 13px; color: var(--text-muted); margin-top: 5px; line-height: 1.4;">Sequência de dias</p>
      </div>
      <div style="background: var(--surface-bg); border-radius: 18px; border: 1px solid var(--border-subtle); padding: 16px 14px 14px; box-shadow: var(--shadow-soft);">
        <i class="fa-solid fa-bullseye" style="font-size: 20px; color: var(--action-primary);" aria-hidden="true"></i>
        <p style="font-size: 26px; font-weight: 600; color: var(--text-primary); margin-top: 10px; line-height: 1;"><%= missoes_semana %></p>
        <p style="font-size: 13px; color: var(--text-muted); margin-top: 5px; line-height: 1.4;">Missões nesta semana</p>
      </div>
      <div style="background: var(--surface-bg); border-radius: 18px; border: 1px solid var(--border-subtle); padding: 16px 14px 14px; box-shadow: var(--shadow-soft);">
        <i class="fa-solid fa-star" style="font-size: 20px; color: var(--action-primary);" aria-hidden="true"></i>
        <p style="font-size: 26px; font-weight: 600; color: var(--text-primary); margin-top: 10px; line-height: 1;"><%= Current.user.xp_total %></p>
        <p style="font-size: 13px; color: var(--text-muted); margin-top: 5px; line-height: 1.4;">XP total</p>
      </div>
      <div style="background: var(--surface-bg); border-radius: 18px; border: 1px solid var(--border-subtle); padding: 16px 14px 14px; box-shadow: var(--shadow-soft);">
        <i class="fa-solid fa-list-check" style="font-size: 20px; color: var(--action-primary);" aria-hidden="true"></i>
        <p style="font-size: 26px; font-weight: 600; color: var(--text-primary); margin-top: 10px; line-height: 1;"><%= total_missoes %></p>
        <p style="font-size: 13px; color: var(--text-muted); margin-top: 5px; line-height: 1.4;">Total de missões</p>
      </div>
    </div>

    <%# ── COMPARATIVO SEMANAL ── %>
    <div style="background: var(--surface-bg); border-radius: 18px; border: 1px solid var(--border-subtle); padding: 18px 16px; box-shadow: var(--shadow-soft);">
      <p style="font-size: 11px; font-weight: 600; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.07em;">Comparativo semanal</p>
      <h2 style="font-size: 17px; font-weight: 600; color: var(--text-primary); margin-top: 3px;">Seu ritmo de aprendizagem</h2>

      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-top: 14px;">
        <div style="background: var(--app-bg); border-radius: 14px; border: 1px solid var(--border-subtle); padding: 14px 12px; text-align: center;">
          <p style="font-size: 12px; font-weight: 600; color: var(--text-muted);">Semana passada</p>
          <p style="font-size: 28px; font-weight: 600; color: var(--text-primary); margin-top: 6px;"><%= @tentativas_semana_passada.count %></p>
          <p style="font-size: 13px; color: var(--text-muted); margin-top: 2px;">missões</p>
        </div>
        <div style="background: var(--action-primary-soft); border-radius: 14px; padding: 14px 12px; text-align: center;">
          <p style="font-size: 12px; font-weight: 600; color: var(--action-primary-strong);">Esta semana</p>
          <p style="font-size: 28px; font-weight: 600; color: var(--action-primary-strong); margin-top: 6px;"><%= missoes_semana %></p>
          <p style="font-size: 13px; color: var(--action-primary); margin-top: 2px;">missões</p>
        </div>
      </div>

      <p style="font-size: 13px; margin-top: 12px; line-height: 1.5; color: <%= diff >= 0 ? 'var(--success)' : 'var(--warning-text)' %>;">
        <% if diff > 0 %>
          Você completou <strong>+<%= diff %> missões</strong> em relação à semana passada.
        <% elsif diff == 0 %>
          Você manteve o mesmo ritmo da semana passada.
        <% else %>
          Você está a <strong><%= diff.abs %> missões</strong> de igualar a semana passada.
        <% end %>
      </p>
    </div>

    <%# ── GRÁFICO XP POR DIA ── %>
    <div style="background: var(--surface-bg); border-radius: 18px; border: 1px solid var(--border-subtle); padding: 18px 16px; box-shadow: var(--shadow-soft);">
      <p style="font-size: 11px; font-weight: 600; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.07em;">XP por dia</p>
      <h2 style="font-size: 17px; font-weight: 600; color: var(--text-primary); margin-top: 3px;">Últimos 7 dias</h2>

      <% if xp_por_dia.any? %>
        <% max_xp = xp_por_dia.map { |d| d[:valor] }.max %>
        <% max_xp = 1 if max_xp.zero? %>
        <% n = xp_por_dia.size %>
        <% bar_w = 32 %>
        <% spacing = 48 %>
        <% svg_w = [n * spacing + 16, 300].max %>
        <% svg_h = 160 %>
        <% max_bar_h = 96 %>
        <% baseline = 128 %>
        <div style="background: var(--app-bg); border-radius: 14px; border: 1px solid var(--border-subtle); margin-top: 14px; padding: 16px 12px 8px; overflow-x: auto;">
          <svg width="100%" viewBox="0 0 <%= svg_w %> <%= svg_h %>" role="img" aria-label="Gráfico de XP por dia nos últimos 7 dias" style="display: block; min-width: <%= svg_w %>px;">
            <defs>
              <linearGradient id="xpGrad" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0%" stop-color="var(--action-primary)"/>
                <stop offset="100%" stop-color="var(--action-primary-strong)"/>
              </linearGradient>
            </defs>
            <% xp_por_dia.each_with_index do |data, i| %>
              <% cx = spacing * i + spacing / 2 + 8 %>
              <% h = [(data[:valor] / max_xp.to_f * max_bar_h).round, 4].max %>
              <% y = baseline - h %>
              <% opacity = 0.35 + (data[:valor] / max_xp.to_f * 0.65) %>
              <rect x="<%= cx - bar_w / 2 %>" y="<%= y %>" width="<%= bar_w %>" height="<%= h %>" rx="6" fill="url(#xpGrad)" opacity="<%= opacity.round(2) %>"/>
              <text x="<%= cx %>" y="<%= y - 6 %>" text-anchor="middle" font-size="11" font-weight="600" fill="var(--text-secondary)"><%= data[:valor] %></text>
              <text x="<%= cx %>" y="<%= svg_h - 4 %>" text-anchor="middle" font-size="11" fill="var(--text-muted)"><%= data[:label] %></text>
            <% end %>
          </svg>
        </div>
      <% else %>
        <div style="background: var(--app-bg); border-radius: 14px; border: 1px solid var(--border-subtle); margin-top: 14px; padding: 24px 16px; text-align: center;">
          <p style="font-size: 15px; font-weight: 600; color: var(--text-primary);">Nenhum XP registrado ainda</p>
          <p style="font-size: 13px; color: var(--text-muted); margin-top: 6px; line-height: 1.5;">Complete missões para acompanhar seu XP diário.</p>
        </div>
      <% end %>
    </div>

    <%# ── GRÁFICO MISSÕES POR SEMANA ── %>
    <div style="background: var(--surface-bg); border-radius: 18px; border: 1px solid var(--border-subtle); padding: 18px 16px; box-shadow: var(--shadow-soft);">
      <p style="font-size: 11px; font-weight: 600; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.07em;">Missões por semana</p>
      <h2 style="font-size: 17px; font-weight: 600; color: var(--text-primary); margin-top: 3px;">Últimas 4 semanas</h2>

      <% if missoes_por_semana.any? %>
        <% max_m = missoes_por_semana.map { |d| d[:valor] }.max %>
        <% max_m = 1 if max_m.zero? %>
        <% n2 = missoes_por_semana.size %>
        <% bar_w2 = 36 %>
        <% spacing2 = 62 %>
        <% side_padding2 = 26 %>
        <% svg_w2 = [[(n2 - 1) * spacing2 + (side_padding2 * 2), 280].max, 320].max %>
        <% svg_h2 = 176 %>
        <% max_bar_h2 = 100 %>
        <% baseline2 = 132 %>
        <% chart_start2 = ((svg_w2 - ((n2 - 1) * spacing2)) / 2.0) - 8 %>
        <div style="background: var(--app-bg); border-radius: 14px; border: 1px solid var(--border-subtle); margin-top: 14px; padding: 16px 10px 10px; overflow-x: auto;">
          <svg width="100%" viewBox="0 0 <%= svg_w2 %> <%= svg_h2 %>" role="img" aria-label="Gráfico de missões por semana nas últimas 4 semanas" style="display: block; min-width: <%= svg_w2 %>px; margin: 0 auto;">
            <defs>
              <linearGradient id="semGrad" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0%" stop-color="var(--action-primary)"/>
                <stop offset="100%" stop-color="var(--action-primary-strong)"/>
              </linearGradient>
            </defs>
            <% missoes_por_semana.each_with_index do |data, i| %>
              <% cx2 = chart_start2 + (spacing2 * i) %>
              <% h2 = [(data[:valor] / max_m.to_f * max_bar_h2).round, 4].max %>
              <% y2 = baseline2 - h2 %>
              <% op2 = 0.35 + (data[:valor] / max_m.to_f * 0.65) %>
              <rect x="<%= cx2 - bar_w2 / 2 %>" y="<%= y2 %>" width="<%= bar_w2 %>" height="<%= h2 %>" rx="8" fill="url(#semGrad)" opacity="<%= op2.round(2) %>"/>
              <text x="<%= cx2 %>" y="<%= y2 - 8 %>" text-anchor="middle" font-size="12" font-weight="600" fill="var(--text-secondary)"><%= data[:valor] %></text>
              <text x="<%= cx2 %>" y="156" text-anchor="middle" font-size="11" fill="var(--text-muted)"><%= data[:label] %></text>
            <% end %>
          </svg>
        </div>
      <% else %>
        <div style="background: var(--app-bg); border-radius: 14px; border: 1px solid var(--border-subtle); margin-top: 14px; padding: 24px 16px; text-align: center;">
          <p style="font-size: 15px; font-weight: 600; color: var(--text-primary);">Nenhuma missão registrada ainda</p>
          <p style="font-size: 13px; color: var(--text-muted); margin-top: 6px; line-height: 1.5;">Seu histórico semanal aparecerá aqui após concluir missões.</p>
        </div>
      <% end %>
    </div>

    <%# ── HISTÓRICO RECENTE ── %>
    <div style="background: var(--surface-bg); border-radius: 18px; border: 1px solid var(--border-subtle); padding: 18px 16px; box-shadow: var(--shadow-soft);">
      <div style="display: flex; align-items: center; justify-content: space-between; gap: 12px;">
        <div>
          <p style="font-size: 11px; font-weight: 600; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.07em;">Histórico recente</p>
          <h2 style="font-size: 17px; font-weight: 600; color: var(--text-primary); margin-top: 3px;">Suas últimas atividades</h2>
        </div>
        <div style="width: 44px; height: 44px; border-radius: 50%; background: var(--app-bg); border: 1px solid var(--border-subtle); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
          <i class="fa-solid fa-clock-rotate-left" style="font-size: 16px; color: var(--action-primary);" aria-hidden="true"></i>
        </div>
      </div>

      <% if tentativas_recentes.any? %>
        <div style="margin-top: 14px; display: flex; flex-direction: column; gap: 10px;">
          <% tentativas_recentes.each do |tentativa| %>
            <% tipo = case tentativa.tipo_missao
               when 'leitura' then { nome: 'Missão de leitura', icone: 'fa-book-open', bg: 'var(--action-primary-soft)', cor: 'var(--action-primary-strong)' }
               when 'foco'    then { nome: 'Missão de foco', icone: 'fa-bullseye', bg: 'var(--surface-success)', cor: 'var(--success)' }
               else                { nome: 'Desafio', icone: 'fa-puzzle-piece', bg: 'var(--surface-warning)', cor: 'var(--warning-text)' }
               end %>
            <div style="background: var(--app-bg); border-radius: 14px; border: 1px solid var(--border-subtle); padding: 14px 12px; display: flex; align-items: center; gap: 12px;">
              <div style="width: 40px; height: 40px; border-radius: 50%; background: <%= tipo[:bg] %>; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                <i class="fa-solid <%= tipo[:icone] %>" style="font-size: 16px; color: <%= tipo[:cor] %>;" aria-hidden="true"></i>
              </div>
              <div style="flex: 1; min-width: 0;">
                <p style="font-size: 12px; color: var(--text-muted);"><%= tentativa.concluida_em.strftime('%d/%m/%Y às %H:%M') %></p>
                <p style="font-size: 14px; font-weight: 600; color: var(--text-primary); margin-top: 2px;"><%= tipo[:nome] %></p>
                <div style="display: flex; gap: 12px; margin-top: 5px; font-size: 12px; color: var(--text-muted);">
                  <span style="display: flex; align-items: center; gap: 4px;">
                    <i class="fa-solid fa-medal" style="color: var(--action-primary);" aria-hidden="true"></i>
                    <%= tentativa.pontuacao %> pts
                  </span>
                  <span style="display: flex; align-items: center; gap: 4px;">
                    <i class="fa-solid fa-clock" style="color: var(--action-primary);" aria-hidden="true"></i>
                    <%= tentativa.tempo_gasto %>s
                  </span>
                </div>
              </div>
              <div style="display: flex; flex-direction: column; align-items: flex-end; gap: 4px; flex-shrink: 0;">
                <span style="font-size: 15px; font-weight: 600; color: var(--success);">+<%= tentativa.xp_ganho %> XP</span>
                <i class="fa-solid fa-chevron-right" style="font-size: 13px; color: var(--text-muted);" aria-hidden="true"></i>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <div style="background: var(--app-bg); border-radius: 14px; border: 1px solid var(--border-subtle); margin-top: 14px; padding: 24px 16px; text-align: center;">
          <p style="font-size: 15px; font-weight: 600; color: var(--text-primary);">Nenhuma atividade registrada ainda</p>
          <p style="font-size: 13px; color: var(--text-muted); margin-top: 6px; line-height: 1.5;">Quando você concluir suas missões, seu histórico aparecerá aqui.</p>
        </div>
      <% end %>
    </div>

    <%# ── CTA ── %>
    <div style="padding-bottom: 24px; padding-top: 8px;">
      <%= link_to 'Iniciar uma Missão',
            missoes_path,
            class: 'btn-primary block min-h-12 w-full rounded-full py-4 text-center text-base font-semibold no-underline' %>
    </div>

  </div>
</div>
