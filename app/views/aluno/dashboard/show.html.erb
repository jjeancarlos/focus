<% diff = @tentativas_semana.count - @tentativas_semana_passada.count %>
<% tentativas_recentes = Current.user.tentativas.order(concluida_em: :desc).limit(4) %>
<% missoes_semana = @tentativas_semana.count %>
<% dias_seguidos = Current.user.sequencia_dias %>
<% progresso_xp = xp_percentual(Current.user) %>

<div class="bg-app min-h-screen pb-28">
  <div class="space-y-5 px-4 pt-8">
    <div class="rounded-[28px] px-5 py-6 shadow-soft" style="background: linear-gradient(180deg, var(--action-primary) 0%, var(--action-primary-strong) 100%);">
      <div class="flex items-center justify-between gap-4">
        <div>
          <p class="text-sm font-semibold uppercase tracking-wide text-white opacity-80">Meu histórico</p>
          <h1 class="mt-2 text-2xl font-bold text-white">Olá, <%= Current.user.name.split.first %>!</h1>
          <p class="mt-2 text-base leading-relaxed text-white opacity-90">Acompanhe seu ritmo, suas conquistas e sua evolução nas missões.</p>
        </div>
        <div class="flex h-16 w-16 shrink-0 items-center justify-center self-center rounded-full text-white" style="background-color: color-mix(in srgb, var(--app-bg) 18%, transparent); line-height: 1;">
          <i class="fa-solid fa-chart-line text-2xl leading-none" aria-hidden="true"></i>
        </div>
      </div>

      <div class="mt-5 rounded-2xl px-4 py-4" style="background-color: color-mix(in srgb, var(--app-bg) 16%, transparent);">
        <div class="flex items-center justify-between gap-3">
          <div>
            <p class="text-sm font-semibold text-white opacity-80">Nível atual</p>
            <p class="mt-1 text-lg font-bold text-white">Nível <%= Current.user.nivel %> · <%= nivel_nome(Current.user.nivel) %></p>
          </div>
          <span class="inline-flex min-w-[92px] shrink-0 items-center justify-center self-center rounded-full px-4 text-sm font-semibold leading-none text-white" style="height: 40px; background-color: color-mix(in srgb, var(--app-bg) 18%, transparent);">
            <span class="leading-none"><%= Current.user.xp_total %> XP</span>
          </span>
        </div>

        <div class="mt-4">
          <div class="mb-2 flex items-center justify-between text-sm text-white opacity-85">
            <span>Progresso para o próximo nível</span>
            <span><%= progresso_xp %>%</span>
          </div>
          <div class="h-3 w-full rounded-full" style="background-color: color-mix(in srgb, var(--app-bg) 22%, transparent);">
            <div class="h-3 rounded-full" style="background-color: var(--app-bg); width: <%= progresso_xp %>%; transition: width 0.6s ease;"></div>
          </div>
        </div>
      </div>
    </div>

    <div class="grid grid-cols-2 gap-3">
      <div class="bg-surface shadow-soft overflow-hidden rounded-2xl p-4">
        <div class="flex items-center justify-between gap-2">
          <div class="min-w-0 flex-1 pr-1">
            <p class="text-muted text-sm font-semibold leading-none">Sequência</p>
            <p class="text-primary mt-2 text-2xl font-bold leading-none"><%= dias_seguidos %></p>
            <p class="text-muted mt-1 text-xs leading-none">dias seguidos</p>
          </div>
          <div class="bg-surface-muted text-primary flex h-10 w-10 shrink-0 items-center justify-center rounded-full" style="line-height: 1;">
            <i class="fa-solid fa-bolt text-sm leading-none" aria-hidden="true"></i>
          </div>
        </div>
      </div>

      <div class="bg-surface shadow-soft overflow-hidden rounded-2xl p-4">
        <div class="flex items-center justify-between gap-2">
          <div class="min-w-0 flex-1 pr-1">
            <p class="text-muted text-sm font-semibold leading-none">Missões</p>
            <p class="text-primary mt-2 text-2xl font-bold leading-none"><%= missoes_semana %></p>
            <p class="text-muted mt-1 text-xs leading-none">nesta semana</p>
          </div>
          <div class="bg-surface-muted text-primary flex h-10 w-10 shrink-0 items-center justify-center rounded-full" style="line-height: 1;">
            <i class="fa-solid fa-bullseye text-sm leading-none" aria-hidden="true"></i>
          </div>
        </div>
      </div>
    </div>

    <div class="bg-surface shadow-soft rounded-2xl p-4">
      <div class="flex items-center justify-between gap-3">
        <div>
          <p class="text-muted text-sm font-semibold">Comparativo semanal</p>
          <h2 class="text-primary mt-1 text-lg font-bold">Seu ritmo de aprendizagem</h2>
        </div>
        <span class="<%= diff >= 0 ? 'bg-surface-success text-success' : 'bg-surface-warning text-warning' %> rounded-full px-3 py-2 text-sm font-semibold"><%= diff > 0 ? "+#{diff}" : diff %></span>
      </div>

      <div class="mt-4 grid grid-cols-2 gap-3">
        <div class="bg-app rounded-2xl p-4 text-center">
          <p class="text-muted text-sm font-semibold">Semana passada</p>
          <p class="text-primary mt-2 text-3xl font-bold"><%= @tentativas_semana_passada.count %></p>
          <p class="text-muted text-sm">missões</p>
        </div>
        <div class="btn-primary rounded-2xl p-4 text-center text-white">
          <p class="text-sm font-semibold text-white opacity-80">Esta semana</p>
          <p class="mt-2 text-3xl font-bold"><%= missoes_semana %></p>
          <p class="text-sm text-white opacity-80">missões</p>
        </div>
      </div>

      <p class="mt-4 text-sm leading-relaxed <%= diff >= 0 ? 'text-success' : 'text-warning' %>"><% if diff > 0 %>Você completou <strong>+<%= diff %> missões</strong> em relação à semana passada.<% elsif diff == 0 %>Você manteve o mesmo ritmo da semana passada.<% else %>Você está a <strong><%= diff.abs %> missões</strong> de igualar a semana passada.<% end %></p>
    </div>

    <div class="bg-surface shadow-soft rounded-2xl p-4">
      <div class="flex items-center justify-between gap-3">
        <div>
          <p class="text-muted text-sm font-semibold">Histórico recente</p>
          <h2 class="text-primary mt-1 text-lg font-bold">Suas últimas atividades</h2>
        </div>
        <div class="bg-app text-primary flex h-11 w-11 items-center justify-center rounded-full">
          <i class="fa-solid fa-clock-rotate-left" aria-hidden="true"></i>
        </div>
      </div>

      <% if tentativas_recentes.any? %>
        <div class="mt-4 space-y-3">
          <% tentativas_recentes.each do |tentativa| %>
            <% cor_tipo = case tentativa.tipo_missao
               when 'leitura' then '#4A6FA5'
               when 'foco' then '#4A8C5C'
               else '#CA8A04'
               end %>
            <% nome_tipo = case tentativa.tipo_missao
               when 'leitura' then 'Missão de leitura'
               when 'foco' then 'Missão de foco'
               else 'Desafio'
               end %>
            <div class="bg-app border-subtle rounded-2xl border p-4">
              <div class="flex items-start justify-between gap-3">
                <div>
                  <span class="inline-flex rounded-full px-3 py-2 text-sm font-semibold text-white" style="background-color: <%= cor_tipo %>;"><%= nome_tipo %></span>
                  <p class="text-primary mt-3 text-base font-semibold"><%= tentativa.concluida_em.strftime('%d/%m às %H:%M') %></p>
                  <p class="text-muted mt-1 text-sm leading-relaxed">Pontuação <%= tentativa.pontuacao %> · Tempo <%= tentativa.tempo_gasto %>s</p>
                </div>
                <div class="text-right">
                  <p class="text-success text-lg font-bold">+<%= tentativa.xp_ganho %> XP</p>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="bg-app border-subtle mt-4 rounded-2xl border p-6 text-center">
          <p class="text-primary text-base font-semibold">Nenhuma atividade registrada ainda</p>
          <p class="text-muted mt-2 text-sm leading-relaxed">Quando você concluir suas missões, seu histórico aparecerá aqui.</p>
        </div>
      <% end %>
    </div>

    <div class="bg-surface shadow-soft rounded-2xl p-4">
      <p class="text-muted text-sm font-semibold">XP por dia</p>
      <h2 class="text-primary mt-1 text-lg font-bold">Últimos 7 dias</h2>
      <% if @xp_por_dia.any? %>
        <div class="bg-app mt-4 rounded-2xl p-3">
          <%= bar_chart @xp_por_dia,
                colors: ['#4A6FA5'],
                height: '170px',
                library: {
                  plugins: { legend: { display: false } },
                  scales: {
                    x: { grid: { display: false }, ticks: { color: '#7A726C', font: { size: 11 } } },
                    y: { grid: { color: '#D4E0F0' }, ticks: { color: '#7A726C', font: { size: 11 } }, beginAtZero: true }
                  }
                } %>
        </div>
      <% else %>
        <p class="text-muted mt-4 py-6 text-center text-sm">Complete missões para acompanhar seu XP diário.</p>
      <% end %>
    </div>

    <div class="bg-surface shadow-soft rounded-2xl p-4">
      <p class="text-muted text-sm font-semibold">Missões por semana</p>
      <h2 class="text-primary mt-1 text-lg font-bold">Últimas 4 semanas</h2>
      <% if @missoes_por_semana.any? %>
        <div class="bg-app mt-4 rounded-2xl p-3">
          <%= column_chart @missoes_por_semana,
                colors: ['#4A6FA5'],
                height: '220px',
                library: {
                  plugins: { legend: { display: false } },
                  scales: {
                    x: { grid: { display: false }, ticks: { color: '#7A726C', font: { size: 11 } } },
                    y: { grid: { color: '#D4E0F0' }, ticks: { color: '#7A726C', font: { size: 11 } }, beginAtZero: true }
                  }
                } %>
        </div>
      <% else %>
        <p class="text-muted mt-4 py-6 text-center text-sm">Nenhuma missão registrada nas últimas semanas.</p>
      <% end %>
    </div>

    <div class="pb-6 pt-2">
      <%= link_to 'Iniciar uma Missão',
            missoes_path,
            class: 'btn-primary block min-h-12 w-full rounded-full py-4 text-center text-base font-semibold' %>
    </div>
  </div>
</div>
