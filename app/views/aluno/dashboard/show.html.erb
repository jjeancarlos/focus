<% diff = @tentativas_semana.count - @tentativas_semana_passada.count %>
<% tentativas_recentes = Current.user.tentativas.order(concluida_em: :desc).limit(4) %>
<% missoes_semana = @tentativas_semana.count %>
<% dias_seguidos = Current.user.sequencia_dias %>
<% progresso_xp = xp_percentual(Current.user) %>

<div class="min-h-screen pb-28" style="background-color: #F5F0E8;">
  <div class="px-4 pt-8 space-y-5">
    <div class="rounded-[28px] px-5 py-6 shadow-sm" style="background: linear-gradient(180deg, #4A6FA5 0%, #3F628F 100%);">
      <div class="flex items-center justify-between gap-4">
        <div>
          <p class="text-sm font-semibold uppercase tracking-wide text-white opacity-80">Meu histórico</p>
          <h1 class="mt-2 text-2xl font-bold text-white">Olá, <%= Current.user.name.split.first %>!</h1>
          <p class="mt-2 text-base leading-relaxed text-white opacity-90">Acompanhe seu ritmo, suas conquistas e sua evolução nas missões.</p>
        </div>
        <div class="flex shrink-0 items-center justify-center rounded-full text-white self-center" style="width: 64px; height: 64px; min-width: 64px; min-height: 64px; background-color: rgba(245, 240, 232, 0.18); line-height: 1;">
          <i class="fa-solid fa-chart-line text-2xl leading-none" aria-hidden="true"></i>
        </div>
      </div>

      <div class="mt-5 rounded-2xl px-4 py-4" style="background-color: rgba(245, 240, 232, 0.16);">
        <div class="flex items-center justify-between gap-3">
          <div>
            <p class="text-sm font-semibold text-white opacity-80">Nível atual</p>
            <p class="mt-1 text-lg font-bold text-white">Nível <%= Current.user.nivel %> · <%= nivel_nome(Current.user.nivel) %></p>
          </div>
          <span class="inline-flex shrink-0 items-center justify-center rounded-full text-sm font-semibold text-white leading-none self-center" style="height: 40px; min-width: 92px; padding: 0 16px; background-color: rgba(245, 240, 232, 0.18); line-height: 1;">
            <span class="leading-none"><%= Current.user.xp_total %> XP</span>
          </span>
        </div>

        <div class="mt-4">
          <div class="mb-2 flex items-center justify-between text-sm text-white opacity-85">
            <span>Progresso para o próximo nível</span>
            <span><%= progresso_xp %>%</span>
          </div>
          <div class="h-3 w-full rounded-full" style="background-color: rgba(245, 240, 232, 0.22);">
            <div class="h-3 rounded-full" style="background-color: #F5F0E8; width: <%= progresso_xp %>%; transition: width 0.6s ease;"></div>
          </div>
        </div>
      </div>
    </div>

    <div class="grid grid-cols-2 gap-3">
      <div class="rounded-2xl p-4 shadow-sm overflow-hidden" style="background-color: #EDE8DF;">
        <div class="flex items-center justify-between gap-2">
          <div class="min-w-0 flex-1 pr-1">
            <p class="text-sm font-semibold leading-none" style="color: #7A726C;">Sequência</p>
            <p class="mt-2 text-2xl font-bold leading-none" style="color: #2C4A7C;"><%= dias_seguidos %></p>
            <p class="mt-1 text-xs leading-none" style="color: #7A726C;">dias seguidos</p>
          </div>
          <div class="flex shrink-0 items-center justify-center rounded-full" style="width: 40px; height: 40px; min-width: 40px; min-height: 40px; background-color: #D4E0F0; color: #2C4A7C; line-height: 1;">
            <i class="fa-solid fa-bolt text-sm leading-none" aria-hidden="true"></i>
          </div>
        </div>
      </div>

      <div class="rounded-2xl p-4 shadow-sm overflow-hidden" style="background-color: #EDE8DF;">
        <div class="flex items-center justify-between gap-2">
          <div class="min-w-0 flex-1 pr-1">
            <p class="text-sm font-semibold leading-none" style="color: #7A726C;">Missões</p>
            <p class="mt-2 text-2xl font-bold leading-none" style="color: #2C4A7C;"><%= missoes_semana %></p>
            <p class="mt-1 text-xs leading-none" style="color: #7A726C;">nesta semana</p>
          </div>
          <div class="flex shrink-0 items-center justify-center rounded-full" style="width: 40px; height: 40px; min-width: 40px; min-height: 40px; background-color: #DDE6F2; color: #2C4A7C; line-height: 1;">
            <i class="fa-solid fa-bullseye text-sm leading-none" aria-hidden="true"></i>
          </div>
        </div>
      </div>
    </div>

    <div class="rounded-2xl p-4 shadow-sm" style="background-color: #EDE8DF;">
      <div class="flex items-center justify-between gap-3">
        <div>
          <p class="text-sm font-semibold" style="color: #7A726C;">Comparativo semanal</p>
          <h2 class="mt-1 text-lg font-bold" style="color: #2C4A7C;">Seu ritmo de aprendizagem</h2>
        </div>
        <span class="rounded-full px-3 py-2 text-sm font-semibold" style="background-color: <%= diff >= 0 ? '#D6EAD9' : '#F5E9C8' %>; color: <%= diff >= 0 ? '#4A8C5C' : '#CA8A04' %>;"><%= diff > 0 ? "+#{diff}" : diff %></span>
      </div>

      <div class="mt-4 grid grid-cols-2 gap-3">
        <div class="rounded-2xl p-4 text-center" style="background-color: #F5F0E8;">
          <p class="text-sm font-semibold" style="color: #7A726C;">Semana passada</p>
          <p class="mt-2 text-3xl font-bold" style="color: #2C4A7C;"><%= @tentativas_semana_passada.count %></p>
          <p class="text-sm" style="color: #7A726C;">missões</p>
        </div>
        <div class="rounded-2xl p-4 text-center text-white" style="background-color: #4A6FA5;">
          <p class="text-sm font-semibold text-white opacity-80">Esta semana</p>
          <p class="mt-2 text-3xl font-bold"><%= missoes_semana %></p>
          <p class="text-sm text-white opacity-80">missões</p>
        </div>
      </div>

      <p class="mt-4 text-sm leading-relaxed" style="color: <%= diff >= 0 ? '#4A8C5C' : '#CA8A04' %>;"><% if diff > 0 %>Você completou <strong>+<%= diff %> missões</strong> em relação à semana passada.<% elsif diff == 0 %>Você manteve o mesmo ritmo da semana passada.<% else %>Você está a <strong><%= diff.abs %> missões</strong> de igualar a semana passada.<% end %></p>
    </div>

    <div class="rounded-2xl p-4 shadow-sm" style="background-color: #EDE8DF;">
      <div class="flex items-center justify-between gap-3">
        <div>
          <p class="text-sm font-semibold" style="color: #7A726C;">Histórico recente</p>
          <h2 class="mt-1 text-lg font-bold" style="color: #2C4A7C;">Suas últimas atividades</h2>
        </div>
        <div class="flex h-11 w-11 items-center justify-center rounded-full" style="background-color: #F5F0E8; color: #2C4A7C;">
          <i class="fa-solid fa-clock-rotate-left" aria-hidden="true"></i>
        </div>
      </div>

      <% if tentativas_recentes.any? %>
        <div class="mt-4 space-y-3">
          <% tentativas_recentes.each do |tentativa| %>
            <% cor_tipo = case tentativa.tipo_missao
               when 'leitura' then '#4A6FA5'
               when 'foco' then '#4A8C5C'
               else '#CA8A04'
               end %>
            <% nome_tipo = case tentativa.tipo_missao
               when 'leitura' then 'Missão de leitura'
               when 'foco' then 'Missão de foco'
               else 'Desafio'
               end %>
            <div class="rounded-2xl p-4" style="background-color: #F5F0E8; border: 1px solid #D9D0C4;">
              <div class="flex items-start justify-between gap-3">
                <div>
                  <span class="inline-flex rounded-full px-3 py-2 text-sm font-semibold" style="background-color: <%= cor_tipo %>; color: #F5F0E8;"><%= nome_tipo %></span>
                  <p class="mt-3 text-base font-semibold" style="color: #2C4A7C;"><%= tentativa.concluida_em.strftime('%d/%m às %H:%M') %></p>
                  <p class="mt-1 text-sm leading-relaxed" style="color: #7A726C;">Pontuação <%= tentativa.pontuacao %> · Tempo <%= tentativa.tempo_gasto %>s</p>
                </div>
                <div class="text-right">
                  <p class="text-lg font-bold" style="color: #4A8C5C;">+<%= tentativa.xp_ganho %> XP</p>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="mt-4 rounded-2xl p-6 text-center" style="background-color: #F5F0E8; border: 1px solid #D9D0C4;">
          <p class="text-base font-semibold" style="color: #2C4A7C;">Nenhuma atividade registrada ainda</p>
          <p class="mt-2 text-sm leading-relaxed" style="color: #7A726C;">Quando você concluir suas missões, seu histórico aparecerá aqui.</p>
        </div>
      <% end %>
    </div>

    <div class="rounded-2xl p-4 shadow-sm" style="background-color: #EDE8DF;">
      <p class="text-sm font-semibold" style="color: #7A726C;">XP por dia</p>
      <h2 class="mt-1 text-lg font-bold" style="color: #2C4A7C;">Últimos 7 dias</h2>
      <% if @xp_por_dia.any? %>
        <div class="mt-4 rounded-2xl p-3" style="background-color: #F5F0E8;">
          <%= bar_chart @xp_por_dia,
                colors: ['#4A6FA5'],
                height: '170px',
                library: {
                  plugins: { legend: { display: false } },
                  scales: {
                    x: { grid: { display: false }, ticks: { color: '#7A726C', font: { size: 11 } } },
                    y: { grid: { color: '#D4E0F0' }, ticks: { color: '#7A726C', font: { size: 11 } }, beginAtZero: true }
                  }
                } %>
        </div>
      <% else %>
        <p class="mt-4 py-6 text-center text-sm" style="color: #7A726C;">Complete missões para acompanhar seu XP diário.</p>
      <% end %>
    </div>

    <div class="rounded-2xl p-4 shadow-sm" style="background-color: #EDE8DF;">
      <p class="text-sm font-semibold" style="color: #7A726C;">Missões por semana</p>
      <h2 class="mt-1 text-lg font-bold" style="color: #2C4A7C;">Últimas 4 semanas</h2>
      <% if @missoes_por_semana.any? %>
        <div class="mt-4 rounded-2xl p-3" style="background-color: #F5F0E8;">
          <%= column_chart @missoes_por_semana,
                colors: ['#4A6FA5'],
                height: '220px',
                library: {
                  plugins: { legend: { display: false } },
                  scales: {
                    x: { grid: { display: false }, ticks: { color: '#7A726C', font: { size: 11 } } },
                    y: { grid: { color: '#D4E0F0' }, ticks: { color: '#7A726C', font: { size: 11 } }, beginAtZero: true }
                  }
                } %>
        </div>
      <% else %>
        <p class="mt-4 py-6 text-center text-sm" style="color: #7A726C;">Nenhuma missão registrada nas últimas semanas.</p>
      <% end %>
    </div>

    <div class="pb-6 pt-2">
      <%= link_to 'Iniciar uma Missão',
            missoes_path,
            class: 'block w-full rounded-full py-4 text-center text-base font-semibold text-white',
            style: 'background-color: #4A6FA5; min-height: 48px;' %>
    </div>
  </div>
</div>
