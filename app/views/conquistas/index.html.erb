<div class="bg-app min-h-screen px-4 pt-8 pb-24">
  <div class="mb-6 flex items-center gap-3">
    <%= back_button_to(aluno_dashboard_path) %>
    <h1 class="text-primary text-xl font-bold">Conquistas</h1>
  </div>

  <div class="space-y-4">
    <div class="bg-surface shadow-soft rounded-2xl p-4">
      <p class="text-muted mb-3 text-sm font-semibold">Seu progresso</p>
      <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
        <div class="bg-app rounded-2xl p-4">
          <p class="text-muted text-sm">Missões de leitura</p>
          <p class="text-primary text-2xl font-bold"><%= @totais_por_tipo["leitura"] %></p>
        </div>
        <div class="bg-app rounded-2xl p-4">
          <p class="text-muted text-sm">Missões de foco</p>
          <p class="text-primary text-2xl font-bold"><%= @totais_por_tipo["foco"] %></p>
        </div>
        <div class="bg-app rounded-2xl p-4">
          <p class="text-muted text-sm">Desafios</p>
          <p class="text-primary text-2xl font-bold"><%= @totais_por_tipo["desafio"] %></p>
        </div>
        <div class="bg-app rounded-2xl p-4">
          <p class="text-muted text-sm">XP total ganho</p>
          <p class="text-primary text-2xl font-bold"><%= @xp_total %></p>
        </div>
        <div class="bg-app rounded-2xl p-4 sm:col-span-2">
          <p class="text-muted text-sm">Sequência atual de dias</p>
          <p class="text-primary text-2xl font-bold"><%= @sequencia_atual %></p>
        </div>
      </div>
    </div>

    <div>
      <p class="text-muted mb-3 text-sm font-semibold uppercase tracking-wide">Marcos alcançados</p>
      <div class="space-y-3">
        <% @conquistas.each do |conquista| %>
          <% bloqueada = !conquista[:desbloqueada] %>
          <div class="bg-surface shadow-soft rounded-2xl p-4" style="opacity: <%= bloqueada ? 0.7 : 1 %>;">
            <div class="flex items-start gap-3">
              <div class="flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-full <%= bloqueada ? 'bg-surface-muted text-muted' : 'bg-app' %>"
                   style="color: <%= bloqueada ? 'var(--text-muted)' : conquista[:cor] %>;">
                <i class="<%= bloqueada ? 'fa-solid fa-lock' : conquista[:icone] %> text-xl" aria-hidden="true"></i>
              </div>
              <div class="min-w-0 flex-1">
                <div class="flex flex-col items-start gap-2 sm:flex-row sm:items-center sm:justify-between">
                  <h2 class="break-words text-base font-semibold <%= bloqueada ? 'text-secondary' : 'text-primary' %>"><%= conquista[:titulo] %></h2>
                  <span class="shrink-0 self-start whitespace-nowrap rounded-full px-3 py-1 text-sm font-semibold <%= bloqueada ? 'bg-surface-muted text-secondary' : 'bg-surface-muted' %>"
                        style="color: <%= bloqueada ? 'var(--text-secondary)' : conquista[:cor] %>;">
                    <%= bloqueada ? 'Bloqueada' : 'Desbloqueada' %>
                  </span>
                </div>
                <p class="text-muted mt-1 text-sm leading-relaxed"><%= conquista[:descricao] %></p>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
