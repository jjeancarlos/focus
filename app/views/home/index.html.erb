<section class="mx-auto flex w-full max-w-3xl flex-col gap-5 py-6">
  <% frases = [
    "Seu ritmo importa. Cada missão concluída é um passo a mais.",
    "Você está construindo progresso com foco e constância.",
    "Hoje é um bom dia para aprender com calma e confiança.",
    "Pequenos avanços de hoje viram grandes conquistas amanhã."
  ] %>
  <% frase_do_dia = frases[Date.current.yday % frases.size] %>

  <div class="bg-surface shadow-soft rounded-2xl px-6 py-8">
    <div class="space-y-4">
      <div>
        <h1 class="text-primary text-2xl font-bold">Focus</h1>
        <p class="text-secondary mt-2 text-base leading-relaxed">
          Uma jornada de aprendizagem com foco, inclusão e progresso no seu ritmo.
        </p>
      </div>

      <%= link_to new_session_path,
            class: "btn-primary flex min-h-12 w-full items-center justify-center gap-2 rounded-full px-6 py-4 text-base font-semibold" do %>
        <i class="fa-solid fa-right-to-bracket" aria-hidden="true"></i>
        Entrar na minha conta
      <% end %>
    </div>
  </div>

  <div class="grid gap-4 md:grid-cols-2">
    <article class="bg-surface shadow-soft rounded-2xl p-5">
      <p class="text-muted text-sm font-semibold">Para alunos</p>
      <p class="text-primary mt-2 text-lg font-bold">Missões, progresso e conquistas</p>
      <p class="text-muted mt-3 text-sm leading-relaxed">Acompanhe sua evolução, complete missões e mantenha sua sequência de estudos.</p>
    </article>

    <article class="bg-surface shadow-soft rounded-2xl p-5">
      <p class="text-muted text-sm font-semibold">Para professores</p>
      <p class="text-primary mt-2 text-lg font-bold">Turmas, alunos e acompanhamento</p>
      <p class="text-muted mt-3 text-sm leading-relaxed">Organize turmas, acompanhe o desempenho dos alunos e envie recados com facilidade.</p>
    </article>
  </div>

  <div class="bg-surface shadow-soft rounded-2xl p-5">
    <p class="text-muted text-sm font-semibold">Frase do dia</p>
    <p class="text-secondary mt-3 text-lg leading-relaxed">
      <i class="fa-solid fa-star text-warning" aria-hidden="true"></i>
      <%= frase_do_dia %>
    </p>
  </div>
</section>
