<div id="confirm-modal"
     class="modal-overlay-theme hidden"
     data-modal-state="closed"
     aria-hidden="true"
     role="dialog"
     aria-modal="true"
     aria-labelledby="confirm-modal-title">
  <div class="modal-card-theme modal-card-theme--confirm relative">
    <div class="mb-6 pt-2 text-center">
      <div class="modal-icon-warning modal-icon-warning--soft mb-4">
        <i class="fa-solid fa-trash-can text-2xl" aria-hidden="true" data-confirm-modal-icon></i>
      </div>
      <h3 id="confirm-modal-title"
          class="text-primary mb-2 text-xl font-bold"
          data-confirm-modal-title>Confirmar ação?</h3>
      <p class="text-muted mx-auto max-w-xs text-sm leading-relaxed"
         data-confirm-modal-message>Revise a ação antes de continuar.</p>
    </div>

    <form id="confirm-modal-form" method="post">
      <input type="hidden" name="_method" value="delete" data-confirm-modal-method>
      <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">

      <div class="grid grid-cols-2 gap-3">
        <button type="button"
                class="btn-secondary text-primary min-h-12 rounded-2xl px-4 py-3 text-base font-semibold"
                data-confirm-modal-cancel>
          Cancelar
        </button>
        <button type="submit"
                class="btn-warning min-h-12 rounded-2xl px-4 py-3 text-base font-semibold"
                data-confirm-modal-submit>
          Confirmar
        </button>
      </div>
    </form>
  </div>
</div>
