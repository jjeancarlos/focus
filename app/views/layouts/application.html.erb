<!DOCTYPE html>
<html class="h-full bg-app" data-theme="light">
  <head>
    <title><%= content_for(:title) || "Focus" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Focus">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <script>
      (() => {
        const storedTheme = window.localStorage.getItem("focus-theme");
        const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
        const theme = storedTheme || (prefersDark ? "dark" : "light");
        document.documentElement.dataset.theme = theme;
      })();
    </script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= javascript_include_tag "chartkick", "Chart.bundle", "data-turbo-track": "reload", defer: true %>
  </head>
  <body class="min-h-screen bg-app font-sans text-base text-primary antialiased">
    <div class="flex min-h-screen flex-col bg-app">
      <% if authenticated? && Current.user&.aluno? %>
        <header class="fixed top-0 left-0 right-0 z-30 flex items-center justify-between border-b border-subtle bg-app px-4 py-3">
          <%= link_to missoes_path do %>
            <%= image_tag "focus_logo1.png", alt: "Focus", class: "h-10 w-auto" %>
          <% end %>
          <div class="flex items-center gap-2">
            <button type="button"
                    id="theme-toggle"
                    class="theme-toggle"
                    aria-label="Ativar modo escuro">
              <i class="fa-solid fa-moon" aria-hidden="true" data-theme-icon></i>
              <span class="sr-only" data-theme-label>Modo escuro</span>
            </button>
            <%= link_to notificacoes_path, class: "theme-toggle relative text-accent", aria: { label: "Notificações" } do %>
              <i class="fa-solid fa-bell text-base" aria-hidden="true"></i>
              <span class="sr-only">Notificações</span>
              <span id="badge-notificacoes"
                    class="bg-[#CA8A04] absolute -top-1 -right-1 hidden min-h-[18px] min-w-[18px] items-center justify-center rounded-full text-[10px] leading-none font-bold text-white">
              </span>
            <% end %>
          </div>
        </header>
      <% else %>
        <button type="button"
                id="theme-toggle"
                class="theme-toggle theme-toggle--floating"
                aria-label="Ativar modo escuro">
          <i class="fa-solid fa-moon" aria-hidden="true" data-theme-icon></i>
          <span class="sr-only" data-theme-label>Modo escuro</span>
        </button>
      <% end %>

      <% if flash.any? %>
        <div class="fixed inset-x-0 z-50 px-4 <%= authenticated? && Current.user&.aluno? ? 'top-16' : 'top-20' %>">
          <div class="mx-auto flex w-full max-w-5xl flex-col gap-3">
            <% flash.each do |type, message| %>
              <% next if message.blank? %>
              <div id="<%= type %>" class="<%= flash_message_classes(type) %> relative overflow-hidden" role="status" aria-live="polite" data-system-alert data-alert-duration="6000">
                <p class="flex items-start gap-2">
                  <span class="pt-0.5"><%= flash_message_icon(type) %></span>
                  <span><%= message %></span>
                </p>
                <div class="absolute bottom-0 left-0 h-1 rounded-full bg-surface-muted" data-alert-bar style="width: 100%;"></div>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>

      <main class="flex flex-1 items-center <%= authenticated? && Current.user&.aluno? ? 'pt-14' : '' %> <%= authenticated? ? 'pb-24' : '' %>">
        <div class="mx-auto w-full max-w-5xl px-4 py-6">
          <%= yield %>
        </div>
      </main>

      <% if authenticated? %>
        <nav class="fixed inset-x-0 bottom-0 z-30 border-t border-subtle backdrop-blur-sm" style="background-color: var(--nav-bg);" aria-label="Navegação principal">
          <div class="mx-auto grid min-h-14 max-w-5xl px-2 pb-[env(safe-area-inset-bottom)]"
               style="grid-template-columns: repeat(<%= bottom_nav_items.count %>, minmax(0, 1fr));">
            <% bottom_nav_items.each do |item| %>
              <%= bottom_nav_link(item) %>
            <% end %>
          </div>
        </nav>
      <% end %>
    </div>

    <script>
      function initializeUiEnhancements() {
        document.querySelectorAll('[data-copy-text]').forEach((button) => {
          if (button.dataset.initialized === 'true') return;
          button.dataset.initialized = 'true';

          button.addEventListener('click', async () => {
            const text = button.dataset.copyText;
            const feedback = button.parentElement.querySelector('[data-copy-feedback]');
            const label = button.querySelector('span');
            const originalLabel = button.dataset.copyLabel || label?.textContent || 'Copiar código';

            try {
              await navigator.clipboard.writeText(text);
              if (label) label.textContent = 'Código copiado';
              if (feedback) feedback.classList.remove('hidden');

              window.setTimeout(() => {
                if (label) label.textContent = originalLabel;
                if (feedback) feedback.classList.add('hidden');
              }, 2000);
            } catch (e) {}
          });
        });

        document.querySelectorAll('[data-system-alert]').forEach((alert) => {
          if (alert.dataset.initialized === 'true') return;
          alert.dataset.initialized = 'true';

          const duration = Number(alert.dataset.alertDuration || 6000);
          const bar = alert.querySelector('[data-alert-bar]');

          if (bar) {
            requestAnimationFrame(() => {
              bar.style.transition = `width ${duration}ms linear`;
              bar.style.width = '0%';
            });
          }

          window.setTimeout(() => {
            alert.style.transition = 'opacity 300ms ease, transform 300ms ease';
            alert.style.opacity = '0';
            alert.style.transform = 'translateY(-8px)';
            window.setTimeout(() => alert.remove(), 300);
          }, duration);
        });
      }

      async function atualizarBadge() {
        const badge = document.getElementById('badge-notificacoes');
        if (!badge) return;

        try {
          const res = await fetch('/notificacoes/contagem');
          const data = await res.json();
          if (data.total > 0) {
            badge.textContent = data.total > 9 ? '9+' : data.total;
            badge.classList.remove('hidden');
            badge.classList.add('flex');
          } else {
            badge.classList.add('hidden');
            badge.classList.remove('flex');
          }
        } catch (e) {}
      }

      function syncThemeToggle() {
        const toggle = document.getElementById('theme-toggle');
        const icon = toggle?.querySelector('[data-theme-icon]');
        const label = toggle?.querySelector('[data-theme-label]');
        if (!toggle || !icon) return;

        const theme = document.documentElement.dataset.theme || 'light';
        const darkModeActive = theme === 'dark';
        const nextModeLabel = darkModeActive ? 'Modo claro' : 'Modo escuro';

        icon.className = darkModeActive ? 'fa-solid fa-sun' : 'fa-solid fa-moon';
        if (label) label.textContent = nextModeLabel;
        toggle.setAttribute('aria-label', `Ativar ${nextModeLabel.toLowerCase()}`);
        toggle.setAttribute('title', nextModeLabel);
        toggle.setAttribute('aria-pressed', String(darkModeActive));

        if (toggle.dataset.initialized === 'true') return;
        toggle.dataset.initialized = 'true';
        toggle.addEventListener('click', () => {
          const currentTheme = document.documentElement.dataset.theme === 'dark' ? 'dark' : 'light';
          const nextTheme = currentTheme === 'dark' ? 'light' : 'dark';
          document.documentElement.dataset.theme = nextTheme;
          window.localStorage.setItem('focus-theme', nextTheme);
          syncThemeToggle();
        });
      }

      function showModalElement(modal) {
        if (!modal) return;
        modal.dataset.modalState = 'opening';
        modal.classList.remove('hidden');
        modal.classList.add('flex');
        modal.setAttribute('aria-hidden', 'false');

        requestAnimationFrame(() => {
          requestAnimationFrame(() => {
            modal.dataset.modalState = 'open';
          });
        });
      }

      function hideModalElement(modal, callback) {
        if (!modal) return;
        modal.dataset.modalState = 'closing';
        modal.setAttribute('aria-hidden', 'true');

        window.setTimeout(() => {
          modal.classList.add('hidden');
          modal.classList.remove('flex');
          modal.dataset.modalState = 'closed';
          callback?.();
        }, 260);
      }

      function initializeConfirmModal() {
        const modal = document.getElementById('confirm-modal');
        if (!modal || modal.dataset.initialized === 'true') return;
        modal.dataset.initialized = 'true';

        const title = modal.querySelector('[data-confirm-modal-title]');
        const message = modal.querySelector('[data-confirm-modal-message]');
        const form = modal.querySelector('#confirm-modal-form');
        const method = modal.querySelector('[data-confirm-modal-method]');
        const submit = modal.querySelector('[data-confirm-modal-submit]');
        const cancel = modal.querySelector('[data-confirm-modal-cancel]');
        const icon = modal.querySelector('[data-confirm-modal-icon]');

        const iconClasses = {
          trash: 'fa-solid fa-trash-can',
          logout: 'fa-solid fa-right-from-bracket'
        };

        const hideModal = () => hideModalElement(modal);

        const showModal = (button) => {
          if (title) title.textContent = button.dataset.confirmTitle || 'Confirmar ação?';
          if (message) message.textContent = button.dataset.confirmMessage || 'Revise a ação antes de continuar.';
          if (form) form.action = button.dataset.confirmAction || '#';
          if (method) method.value = button.dataset.confirmMethod || 'delete';
          if (submit) submit.textContent = button.dataset.confirmButton || 'Confirmar';
          if (icon) icon.className = iconClasses[button.dataset.confirmIcon] || iconClasses.trash;
          showModalElement(modal);
        };

        cancel?.addEventListener('click', hideModal);
        modal.addEventListener('click', (event) => {
          if (event.target === modal) hideModal();
        });
        document.addEventListener('keydown', (event) => {
          if (event.key === 'Escape' && modal.getAttribute('aria-hidden') === 'false') {
            hideModal();
          }
        });

        document.querySelectorAll('[data-confirm-modal-open]').forEach((button) => {
          if (button.dataset.modalInitialized === 'true') return;
          button.dataset.modalInitialized = 'true';
          button.addEventListener('click', () => showModal(button));
        });
      }

      function initializeReportLoadingModal() {
        const modal = document.getElementById('report-loading-modal');
        const trigger = document.querySelector('[data-loading-report]');
        if (!modal || !trigger || trigger.dataset.loadingInitialized === 'true') return;

        trigger.dataset.loadingInitialized = 'true';
        const message = modal.querySelector('[data-loading-report-message]');
        const messages = [
          'Conectando com a IA...',
          'Coletando os dados do aluno...',
          'Analisando desempenho e progresso...',
          'Montando o relatório em PDF...',
          'Finalizando seu arquivo...'
        ];

        const showModal = () => {
          showModalElement(modal);
        };

        const hideModal = () => {
          window.clearInterval(modal.loadingIntervalId);
          window.clearTimeout(modal.loadingDelayId);
          modal.loadingAbortController = null;
          hideModalElement(modal, () => {
            trigger.dataset.loadingActive = 'false';
            trigger.classList.remove('opacity-50', 'cursor-not-allowed', 'pointer-events-none');
          });
        };

        const abortLoading = () => {
          modal.loadingAbortController?.abort();
          hideModal();
        };

        const rotateMessages = () => {
          let index = 0;
          if (message) {
            message.textContent = messages[0];
            message.style.opacity = '1';
          }

          window.clearInterval(modal.loadingIntervalId);
          modal.loadingIntervalId = window.setInterval(() => {
            if (!message) return;
            message.style.opacity = '0.5';
            window.setTimeout(() => {
              index += 1;
              message.textContent = messages[index % messages.length];
              message.style.opacity = '1';
            }, 450);
          }, 3200);
        };

        modal.addEventListener('click', (event) => {
          if (event.target === modal && trigger.dataset.loadingActive === 'true') {
            abortLoading();
          }
        });

        trigger.addEventListener('click', async (event) => {
          event.preventDefault();
          if (trigger.dataset.loadingActive === 'true') return;

          trigger.dataset.loadingActive = 'true';
          trigger.classList.add('opacity-50', 'cursor-not-allowed', 'pointer-events-none');
          showModal();
          rotateMessages();

          const controller = new AbortController();
          modal.loadingAbortController = controller;

          try {
            await new Promise((resolve, reject) => {
              modal.loadingDelayId = window.setTimeout(resolve, 3000);
              controller.signal.addEventListener('abort', () => {
                window.clearTimeout(modal.loadingDelayId);
                reject(new DOMException('Aborted', 'AbortError'));
              }, { once: true });
            });

            const response = await fetch(trigger.href, {
              method: 'GET',
              headers: {
                'X-Requested-With': 'XMLHttpRequest',
                'Accept': 'application/pdf'
              },
              signal: controller.signal
            });

            const contentType = response.headers.get('Content-Type') || '';

            if (!response.ok || !contentType.includes('application/pdf')) {
              throw new Error('Falha ao gerar relatório');
            }

            const blob = await response.blob();
            const disposition = response.headers.get('Content-Disposition') || '';
            const fileNameMatch = disposition.match(/filename="?([^";]+)"?/i);
            const fileName = fileNameMatch ? fileNameMatch[1] : 'relatorio.pdf';
            const blobUrl = window.URL.createObjectURL(blob);
            const downloadLink = document.createElement('a');
            downloadLink.href = blobUrl;
            downloadLink.download = fileName;
            document.body.appendChild(downloadLink);
            downloadLink.click();
            downloadLink.remove();
            window.URL.revokeObjectURL(blobUrl);
            hideModal();
          } catch (error) {
            hideModal();

            if (error.name === 'AbortError') return;

            window.location.href = trigger.href;
          }
        });
      }

      function initializeLayoutScripts() {
        initializeUiEnhancements();
        syncThemeToggle();
        atualizarBadge();
        initializeConfirmModal();
        initializeReportLoadingModal();
      }

      document.addEventListener('turbo:load', initializeLayoutScripts);
      document.addEventListener('DOMContentLoaded', initializeLayoutScripts);
    </script>
  </body>
</html>
