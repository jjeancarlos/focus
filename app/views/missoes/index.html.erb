<div class="mx-auto max-w-3xl space-y-6 pb-8">
  <div class="space-y-2 px-1">
    <h1 class="text-primary text-2xl font-bold">Escolha sua Missão</h1>
    <p class="text-muted text-base">Selecione o tipo de prática que faz mais sentido para você agora.</p>
  </div>

  <% if flash[:alert] == "limite_atingido" %>
    <div class="bg-surface-warning shadow-soft rounded-2xl px-4 py-4">
      <p class="text-warning text-base font-semibold leading-relaxed">Você completou suas 10 missões de hoje. Descanse um pouco e volte amanhã para continuar sua sequência.</p>
    </div>
  <% end %>

  <div class="space-y-4">
    <% cards = [
      {
        tipo: "leitura",
        titulo: "Leitura Guiada",
        descricao: "Treino de leitura com foco em compreensão",
        xp: "Até 30 XP",
        icon: :leitura
      },
      {
        tipo: "foco",
        titulo: "Missão de Foco",
        descricao: "Observação e memória visual",
        xp: "Até 40 XP",
        icon: :foco
      },
      {
        tipo: "desafio",
        titulo: "Desafio",
        descricao: "Sequência de palavras com imagens",
        xp: "Até 50 XP + bônus",
        icon: :desafio
      }
    ] %>

    <% cards.each do |card| %>
      <% disponivel = @missoes_por_tipo[card[:tipo]] %>
      <% classes = "bg-surface shadow-soft interactive-card block rounded-2xl px-4 py-6" %>

      <% if @limite_diario_atingido %>
        <div class="bg-surface shadow-soft relative cursor-not-allowed rounded-2xl px-4 py-6 opacity-50">
          <div class="bg-surface-warning text-warning absolute right-4 top-4 rounded-full px-3 py-2 text-sm font-semibold">
            Disponível amanhã <i class="fa-solid fa-clock" aria-hidden="true"></i>
          </div>
          <div class="flex items-start gap-4">
            <div class="bg-surface-muted text-accent flex h-12 w-12 items-center justify-center rounded-full">
              <%= mission_icon(card[:icon]) %>
            </div>
            <div class="space-y-2">
              <h2 class="text-primary text-xl font-semibold"><%= card[:titulo] %></h2>
              <p class="text-muted text-base leading-relaxed"><%= card[:descricao] %></p>
              <p class="text-success text-base font-semibold"><%= card[:xp] %></p>
            </div>
          </div>
        </div>
      <% elsif disponivel %>
        <%= link_to missao_path(card[:tipo]), class: classes do %>
          <div class="flex items-start gap-4">
            <div class="bg-surface-muted text-accent flex h-12 w-12 items-center justify-center rounded-full">
              <%= mission_icon(card[:icon]) %>
            </div>
            <div class="space-y-2">
              <h2 class="text-primary text-xl font-semibold"><%= card[:titulo] %></h2>
              <p class="text-muted text-base leading-relaxed"><%= card[:descricao] %></p>
              <p class="text-success text-base font-semibold"><%= card[:xp] %></p>
            </div>
          </div>
        <% end %>
      <% else %>
        <div class="bg-surface shadow-soft rounded-2xl px-4 py-6 opacity-75">
          <div class="flex items-start gap-4">
            <div class="bg-surface-muted text-accent flex h-12 w-12 items-center justify-center rounded-full">
              <%= mission_icon(card[:icon]) %>
            </div>
            <div class="space-y-2">
              <h2 class="text-primary text-xl font-semibold"><%= card[:titulo] %></h2>
              <p class="text-muted text-base leading-relaxed"><%= card[:descricao] %></p>
              <p class="text-muted text-base font-semibold">Em breve</p>
            </div>
          </div>
        </div>
      <% end %>
    <% end %>
  </div>
</div>
