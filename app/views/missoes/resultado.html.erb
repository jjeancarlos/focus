<div class="mx-auto max-w-3xl space-y-6 pb-8" data-resultado-root>
  <div class="bg-surface shadow-soft rounded-2xl p-6 text-center">
    <p class="text-muted text-sm font-semibold uppercase tracking-wide">Missão concluída</p>
    <h1 class="text-primary mt-2 text-4xl font-bold">+<%= @tentativa.xp_ganho %> XP</h1>
    <p class="text-success mt-3 text-base font-semibold"><%= @mensagem %></p>
    <p class="text-muted mt-2 text-base">Acertos: <%= @tentativa.pontuacao %> de <%= @total_perguntas %> corretos</p>
  </div>

  <div class="space-y-3">
    <%= link_to "Fazer outra missão", missoes_path, class: "btn-primary block min-h-12 w-full rounded-full px-6 py-4 text-center text-base font-semibold" %>
    <%= link_to "Ver meu progresso", aluno_dashboard_path, class: "btn-secondary block min-h-12 w-full rounded-full px-6 py-4 text-center text-base font-semibold" %>
  </div>
</div>

<% if @mostrar_modal_conclusao %>
  <div class="modal-overlay-theme fixed inset-0 z-50 flex items-center justify-center px-4" data-modal-state="open" data-conclusao-modal>
    <div class="modal-card-theme relative z-10 w-full max-w-lg px-6 py-8 text-center">
      <div class="space-y-4">
        <div class="text-accent text-5xl"><i class="fa-solid fa-party-horn" aria-hidden="true"></i></div>
        <h2 class="text-primary text-2xl font-bold">Incrível! Você completou o dia!</h2>
        <p class="text-muted text-base leading-relaxed">Você fez 10 missões hoje. Descanse e volte amanhã para continuar sua sequência!</p>
        <p class="text-accent text-lg font-semibold">XP ganho hoje: <%= @xp_hoje %> XP</p>
        <%= link_to "Ver meu progresso", aluno_dashboard_path, class: "btn-primary block min-h-12 w-full rounded-full px-6 py-4 text-base font-semibold" %>
      </div>
    </div>
  </div>
<% end %>
