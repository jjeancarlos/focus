<div class="mx-auto max-w-3xl space-y-6 pb-8" data-missao-root data-missao-tipo="<%= @atividade.tipo %>" data-duration="<%= @tempo_visual %>">
  <div class="space-y-2">
    <p class="text-sm font-semibold uppercase tracking-wide" style="color: #7A726C;"><%= @atividade.tipo.humanize %></p>
    <h1 class="text-2xl font-bold" style="color: #2C4A7C;"><%= @atividade.titulo %></h1>
    <p class="text-base leading-relaxed" style="color: #7A726C;"><%= @atividade.descricao %></p>
  </div>

  <% if @atividade.tipo == "desafio" %>
    <div class="mx-auto w-full max-w-2xl rounded-2xl px-4 py-4 shadow-sm" style="background-color: #EDE8DF;">
      <div class="space-y-3">
        <div class="flex items-center justify-between gap-3">
          <p class="text-sm font-semibold" style="color: #2C4A7C;">Tempo de organização</p>
          <p class="text-sm" data-timer-message style="color: #7A726C;">Organize as palavras no seu ritmo.</p>
        </div>
        <div class="h-3 w-full overflow-hidden rounded-full" style="background-color: #D4E0F0;">
          <div data-timer-bar class="h-full rounded-full" style="width: 0%; background-color: #4A6FA5;"></div>
        </div>
      </div>
    </div>
  <% end %>

  <%= form_with url: responder_missao_path(@atividade.tipo), method: :post, local: true, class: "space-y-6" do |form| %>
    <% if @atividade.tipo == "leitura" %>
      <div class="rounded-2xl p-6 shadow-sm" style="background-color: #EDE8DF;">
        <p class="text-base leading-loose" style="color: #1C1917;"><%= simple_format(@atividade.conteudo) %></p>
      </div>
    <% end %>

    <% if @atividade.tipo == "foco" %>
      <div class="space-y-3" data-foco-bloco>
        <div class="flex items-center justify-between">
          <p class="text-sm font-semibold" style="color: #2C4A7C;">Tempo de observação</p>
          <div class="rounded-full px-4 py-2 text-sm font-semibold shadow-sm" data-foco-timer style="background-color: #DDE6F2; color: #2C4A7C; min-width: 56px; text-align: center;">
            10s
          </div>
        </div>
        <div class="h-3 w-full overflow-hidden rounded-full" style="background-color: #D4E0F0;">
          <div data-timer-bar class="h-full rounded-full" style="width: 0%; background-color: #4A6FA5;"></div>
        </div>
        <p class="text-sm" data-timer-message style="color: #7A726C;">Observe a imagem com calma. As perguntas aparecem quando o tempo acabar.</p>
        <div data-foco-imagem class="rounded-2xl p-4 shadow-sm" style="background-color: #EDE8DF;">
          <%= image_tag asset_path(@atividade.imagem_url), class: "w-full rounded-2xl object-cover", style: "max-height: 280px;", alt: "Imagem da missão de foco" %>
        </div>
      </div>
      <p class="hidden rounded-2xl px-4 py-3 text-base font-medium" data-foco-feedback style="background-color: #DDE6F2; color: #2C4A7C;">
        Boa observação. Continue assim.
      </p>
    <% end %>

    <div data-perguntas-container class="space-y-4 <%= @atividade.tipo == "foco" ? "hidden" : "" %>">
      <% @perguntas.each_with_index do |pergunta, index| %>
        <% if @atividade.tipo == "desafio" %>
          <div class="rounded-2xl p-5 shadow-sm" style="background-color: #EDE8DF;" data-desafio-item data-desafio-id="<%= pergunta["id"] %>">
            <div class="space-y-4">
              <div>
                <p class="text-sm font-semibold" style="color: #7A726C;">Etapa <%= index + 1 %></p>
                <h2 class="text-lg font-semibold" style="color: #2C4A7C;"><%= pergunta["enunciado"] %></h2>
              </div>

              <div class="flex min-h-16 flex-wrap gap-2 rounded-2xl border border-dashed p-3" style="border-color: #B8C9E0; background-color: #F5F0E8;" data-desafio-resposta></div>
              <input type="hidden" name="desafio_respostas[<%= pergunta["id"] %>]" value="" data-desafio-input>

              <div class="flex flex-wrap gap-2" data-desafio-banco>
                <% @palavras_embaralhadas[pergunta].each do |palavra| %>
                  <button type="button" class="rounded-full px-4 py-3 text-base font-semibold" style="background-color: #DDE6F2; color: #2C4A7C;" data-palavra><%= palavra %></button>
                <% end %>
              </div>
            </div>
          </div>
        <% elsif @atividade.tipo == "foco" %>
          <div class="rounded-2xl p-5 shadow-sm <%= index.zero? ? "" : "hidden" %>" style="background-color: #EDE8DF;" data-foco-pergunta>
            <div class="space-y-4">
              <div>
                <p class="text-sm font-semibold" style="color: #7A726C;">Pergunta <%= index + 1 %></p>
                <h2 class="text-lg font-semibold" style="color: #2C4A7C;"><%= pergunta["enunciado"] %></h2>
              </div>

              <div class="space-y-3">
                <% Array(pergunta["opcoes"]).each_with_index do |opcao, opcao_index| %>
                  <label class="block cursor-pointer rounded-2xl border px-4 py-4 text-base font-semibold transition" style="border-color: #D9D0C4; background-color: #F5F0E8; min-height: 48px; color: #1C1917;" data-foco-opcao>
                    <%= radio_button_tag "respostas[#{pergunta["id"]}]", opcao_index, false, class: "sr-only", required: true %>
                    <span><%= opcao %></span>
                  </label>
                <% end %>
              </div>
            </div>
          </div>
        <% else %>
          <div class="rounded-2xl p-5 shadow-sm" style="background-color: #EDE8DF;">
            <div class="space-y-4">
              <div>
                <p class="text-sm font-semibold" style="color: #7A726C;">Pergunta <%= index + 1 %></p>
                <h2 class="text-lg font-semibold" style="color: #2C4A7C;"><%= pergunta["enunciado"] %></h2>
              </div>

              <div class="space-y-3">
                <% Array(pergunta["opcoes"]).each_with_index do |opcao, opcao_index| %>
                  <label class="flex cursor-pointer items-center gap-3 rounded-2xl border px-4 py-4" style="border-color: #D9D0C4; background-color: #F5F0E8; min-height: 48px;">
                    <%= radio_button_tag "respostas[#{pergunta["id"]}]", opcao_index, false, class: "h-5 w-5", required: true %>
                    <span class="text-base" style="color: #1C1917;"><%= opcao %></span>
                  </label>
                <% end %>
              </div>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>

    <%= form.submit "Concluir missão", class: "w-full rounded-full px-6 py-4 text-base font-semibold text-white #{@atividade.tipo == "foco" ? "hidden" : ""}", style: "background-color: #4A6FA5;", disabled: (@atividade.tipo == "foco"), data: { submit_missao: true } %>
  <% end %>
</div>

<script>
  const initializeMissionView = () => {
    const root = document.querySelector("[data-missao-root]");
    if (!root || root.dataset.initialized === "true") return;

    root.dataset.initialized = "true";

    const tipo = root.dataset.missaoTipo;
    const duration = Number(root.dataset.duration || 0);
    const timerBar = root.querySelector("[data-timer-bar]");
    const timerMessage = root.querySelector("[data-timer-message]");

    if (timerBar && duration > 0) {
      requestAnimationFrame(() => {
        timerBar.style.transition = `width ${duration}s linear`;
        timerBar.style.width = "100%";
      });
    }

    if (tipo === "foco") {
      const imagem = root.querySelector("[data-foco-imagem]");
      const perguntasContainer = root.querySelector("[data-perguntas-container]");
      const perguntas = Array.from(root.querySelectorAll("[data-foco-pergunta]"));
      const feedback = root.querySelector("[data-foco-feedback]");
      const submit = root.querySelector("[data-submit-missao]");
      const focusTimer = root.querySelector("[data-foco-timer]");

      const showQuestion = (index) => {
        perguntas.forEach((pergunta, currentIndex) => {
          pergunta.classList.toggle("hidden", currentIndex !== index);
        });
      };

      const updateOptionStyles = (question) => {
        question.querySelectorAll("[data-foco-opcao]").forEach((option) => {
          const input = option.querySelector('input[type="radio"]');
          option.style.backgroundColor = input.checked ? "#D4E0F0" : "#F5F0E8";
          option.style.borderColor = input.checked ? "#AFC4E0" : "#D9D0C4";
        });
      };

      perguntas.forEach((question, index) => {
        question.querySelectorAll('input[type="radio"]').forEach((input) => {
          input.addEventListener("change", () => {
            updateOptionStyles(question);
            if (feedback) {
              feedback.classList.remove("hidden");
              feedback.textContent = index === perguntas.length - 1 ? "Boa observação. Você já pode concluir sua missão." : "Boa observação. Vamos para a próxima.";
            }

            const nextQuestion = perguntas[index + 1];
            if (nextQuestion) {
              window.setTimeout(() => showQuestion(index + 1), 300);
            } else if (submit) {
              submit.disabled = false;
              submit.classList.remove("hidden");
            }
          });
        });
      });

      let remaining = duration || 10;
      if (focusTimer) focusTimer.textContent = `${remaining}s`;

      const countdown = window.setInterval(() => {
        remaining -= 1;
        if (focusTimer) focusTimer.textContent = `${Math.max(remaining, 0)}s`;

        if (remaining <= 0) {
          window.clearInterval(countdown);
          if (imagem) imagem.classList.add("hidden");
          if (perguntasContainer) perguntasContainer.classList.remove("hidden");
          showQuestion(0);
          if (timerMessage) timerMessage.textContent = "Agora escolha a melhor resposta com calma.";
        }
      }, 1000);
    }

    if (tipo === "desafio") {
      root.querySelectorAll("[data-desafio-item]").forEach((item) => {
        const banco = item.querySelector("[data-desafio-banco]");
        const resposta = item.querySelector("[data-desafio-resposta]");
        const input = item.querySelector("[data-desafio-input]");

        const sync = () => {
          const palavras = Array.from(resposta.querySelectorAll("button[data-palavra-selecionada]")).map((node) => node.dataset.value);
          input.value = palavras.join("||");
        };

        banco.querySelectorAll("[data-palavra]").forEach((button) => {
          button.addEventListener("click", () => {
            const selected = document.createElement("button");
            selected.type = "button";
            selected.dataset.palavraSelecionada = "true";
            selected.dataset.value = button.textContent.trim();
            selected.className = "rounded-full px-4 py-3 text-base font-semibold";
            selected.style.backgroundColor = "#4A6FA5";
            selected.style.color = "#FFFFFF";
            selected.textContent = button.textContent.trim();

            selected.addEventListener("click", () => {
              button.classList.remove("hidden");
              selected.remove();
              sync();
            });

            resposta.appendChild(selected);
            button.classList.add("hidden");
            sync();
          });
        });
      });

      if (timerMessage && duration > 0) {
        window.setTimeout(() => {
          timerMessage.textContent = "Você já pode concluir quando quiser.";
        }, duration * 1000);
      }
    }
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initializeMissionView);
  } else {
    initializeMissionView();
  }

  document.addEventListener("turbo:load", initializeMissionView);
</script>
