<div class="mx-auto max-w-3xl space-y-6 pb-8" data-missao-root data-missao-tipo="<%= @atividade.tipo %>" data-duration="<%= @tempo_visual %>" data-feedback-messages="<%= json_escape(@feedback_messages.to_json) %>">
  <div class="space-y-2">
    <p class="text-muted text-sm font-semibold uppercase tracking-wide"><%= @atividade.tipo.humanize %></p>
    <h1 class="text-primary text-2xl font-bold"><%= @atividade.titulo %></h1>
    <p class="text-muted text-base leading-relaxed"><%= @atividade.descricao %></p>
  </div>

  <% if @atividade.tipo == "desafio" %>
    <div class="bg-surface shadow-soft mx-auto w-full max-w-2xl rounded-2xl px-4 py-4">
      <div class="space-y-3">
        <div class="flex items-center justify-between gap-3">
          <p class="text-primary text-sm font-semibold">Tempo de organização</p>
          <p class="text-muted text-sm" data-timer-message>Organize as palavras no seu ritmo.</p>
        </div>
        <div class="bg-surface-muted h-3 w-full overflow-hidden rounded-full">
          <div data-timer-bar class="h-full rounded-full" style="width: 0%; background-color: var(--action-primary);"></div>
        </div>
      </div>
    </div>
  <% end %>

  <%= form_with url: responder_missao_path(@atividade.tipo), method: :post, local: true, class: "space-y-6", data: { missao_form: true } do |form| %>
    <% if @atividade.tipo == "leitura" %>
      <div class="bg-surface shadow-soft rounded-2xl p-6">
        <p class="text-primary text-base leading-loose"><%= simple_format(@atividade.conteudo) %></p>
      </div>
    <% end %>

    <% if @atividade.tipo == "foco" %>
      <div class="space-y-3" data-foco-bloco>
        <div class="flex items-center justify-between">
          <p class="text-primary text-sm font-semibold">Tempo de observação</p>
          <div class="bg-surface-muted text-primary rounded-full px-4 py-2 text-sm font-semibold shadow-soft" data-foco-timer style="min-width: 56px; text-align: center;">
            10s
          </div>
        </div>
        <div class="bg-surface-muted h-3 w-full overflow-hidden rounded-full">
          <div data-timer-bar class="h-full rounded-full" style="width: 0%; background-color: var(--action-primary);"></div>
        </div>
        <p class="text-muted text-sm" data-timer-message>Observe a imagem com calma. As perguntas aparecem quando o tempo acabar.</p>
        <div data-foco-imagem class="bg-surface shadow-soft rounded-2xl p-4">
          <%= image_tag asset_path(@atividade.imagem_url), class: "w-full rounded-2xl object-cover", style: "max-height: 280px;", alt: "Imagem da missão de foco" %>
        </div>
      </div>
    <% end %>

    <div data-perguntas-container class="space-y-4 <%= @atividade.tipo == "foco" ? "hidden" : "" %>">
      <% @perguntas.each_with_index do |pergunta, index| %>
        <% correta_texto = if @atividade.tipo == "desafio"
             Array(pergunta["ordem_correta"]).join(" ")
           else
             Array(pergunta["opcoes"])[pergunta["correta_index"].to_i]
           end %>
        <% proximo_label = index == @perguntas.size - 1 ? "Ver resultado" : "Próxima pergunta" %>

        <div class="bg-surface shadow-soft rounded-2xl p-5 <%= index.zero? ? "" : "hidden" %>" data-question-card data-question-index="<%= index %>" data-next-label="<%= proximo_label %>" data-correct-text="<%= correta_texto %>">
          <div class="space-y-4">
            <div>
              <p class="text-muted text-sm font-semibold">
                <%= @atividade.tipo == "desafio" ? "Etapa" : "Pergunta" %> <%= index + 1 %>
              </p>
              <h2 class="text-primary text-lg font-semibold"><%= pergunta["enunciado"] %></h2>
            </div>

            <% if @atividade.tipo == "desafio" %>
              <div class="space-y-4" data-desafio-item data-correct-order="<%= Array(pergunta["ordem_correta"]).join("||") %>">
                <div class="bg-app border-subtle flex min-h-16 flex-wrap gap-2 rounded-2xl border border-dashed p-3" data-desafio-resposta></div>
                <input type="hidden" name="desafio_respostas[<%= pergunta["id"] %>]" value="" data-desafio-input>

                <div class="flex flex-wrap gap-2" data-desafio-banco>
                  <% @palavras_embaralhadas[pergunta].each do |palavra| %>
                    <button type="button" class="bg-surface-muted text-primary rounded-full px-4 py-3 text-base font-semibold" style="min-height: 48px;" data-palavra><%= palavra %></button>
                  <% end %>
                </div>

                <button type="button" class="btn-primary min-h-12 w-full rounded-full px-6 py-4 text-base font-semibold" data-check-answer>
                  <%= proximo_label %>
                </button>
              </div>
            <% else %>
              <div class="space-y-3">
                <% Array(pergunta["opcoes"]).each_with_index do |opcao, opcao_index| %>
                  <label class="bg-app border-subtle text-primary block cursor-pointer rounded-2xl border px-4 py-4 text-base font-semibold transition" style="min-height: 48px;" data-choice-option data-correct="<%= opcao_index == pergunta["correta_index"].to_i %>">
                    <%= radio_button_tag "respostas[#{pergunta["id"]}]", opcao_index, false, class: "sr-only", required: index.zero? %>
                    <span><%= opcao %></span>
                  </label>
                <% end %>
              </div>
            <% end %>

            <div class="bg-surface-warning hidden space-y-4 rounded-2xl px-4 py-4" data-answer-feedback>
              <p class="text-warning text-base font-semibold leading-relaxed" data-feedback-message></p>
              <p class="text-muted text-base leading-relaxed">
                Resposta correta: <span class="text-primary font-semibold" data-feedback-correct></span>
              </p>
              <button type="button" class="btn-primary min-h-12 w-full rounded-full px-6 py-4 text-base font-semibold" data-feedback-next>
                <%= proximo_label %>
              </button>
            </div>
          </div>
        </div>
      <% end %>
    </div>

    <%= form.submit "Ver resultado", class: "btn-primary hidden min-h-12 w-full rounded-full px-6 py-4 text-base font-semibold", data: { submit_missao: true } %>
  <% end %>
</div>

<script>
  const initializeMissionView = () => {
    const root = document.querySelector("[data-missao-root]");
    if (!root || root.dataset.initialized === "true") return;

    root.dataset.initialized = "true";

    const tipo = root.dataset.missaoTipo;
    const duration = Number(root.dataset.duration || 0);
    const timerBar = root.querySelector("[data-timer-bar]");
    const timerMessage = root.querySelector("[data-timer-message]");
    const questions = Array.from(root.querySelectorAll("[data-question-card]"));
    const submit = root.querySelector("[data-submit-missao]");
    const feedbackTemplates = JSON.parse(root.dataset.feedbackMessages || "[]");

    const feedbackMessageFor = () => {
      const templates = feedbackTemplates.length > 0 ? feedbackTemplates : [{ icon: "fa-solid fa-hand-fist", text: "Quase lá! Continue tentando." }];
      return templates[Math.floor(Math.random() * templates.length)];
    };

    const showQuestion = (index) => {
      questions.forEach((question, currentIndex) => {
        question.classList.toggle("hidden", currentIndex !== index);
      });
    };

    const finishMission = () => {
      if (submit) {
        submit.classList.remove("hidden");
        submit.click();
      }
    };

    const goToNextStep = (index) => {
      const nextQuestion = questions[index + 1];
      if (nextQuestion) {
        showQuestion(index + 1);
      } else {
        finishMission();
      }
    };

    const showFeedback = (question, message) => {
      const feedback = question.querySelector("[data-answer-feedback]");
      const feedbackText = question.querySelector("[data-feedback-message]");
      const feedbackCorrect = question.querySelector("[data-feedback-correct]");

      if (!feedback || !feedbackText || !feedbackCorrect) return;

      feedbackText.innerHTML = `<i class="${message.icon}" aria-hidden="true"></i> ${message.text}`;
      feedbackCorrect.textContent = question.dataset.correctText;
      feedback.classList.remove("hidden");
    };

    const hideFeedback = (question) => {
      const feedback = question.querySelector("[data-answer-feedback]");
      if (feedback) feedback.classList.add("hidden");
    };

    const lockChoices = (question) => {
      question.querySelectorAll("[data-choice-option]").forEach((option) => {
        option.classList.add("pointer-events-none");
      });
    };

    const updateChoiceStyles = (question) => {
      question.querySelectorAll("[data-choice-option]").forEach((option) => {
        const input = option.querySelector('input[type="radio"]');
        if (input.checked) {
          option.style.backgroundColor = "var(--surface-muted)";
          option.style.borderColor = "var(--action-primary)";
          option.style.color = "var(--action-primary-strong)";
        } else {
          option.style.backgroundColor = "var(--app-bg)";
          option.style.borderColor = "var(--border-subtle)";
          option.style.color = "var(--text-primary)";
        }
      });
    };

    questions.forEach((question, index) => {
      const nextButton = question.querySelector("[data-feedback-next]");
      if (nextButton) {
        nextButton.addEventListener("click", () => {
          hideFeedback(question);
          goToNextStep(index);
        });
      }

      question.querySelectorAll('input[type="radio"]').forEach((input) => {
        input.addEventListener("change", () => {
          updateChoiceStyles(question);
          lockChoices(question);
          input.required = false;

          if (input.closest("[data-choice-option]")?.dataset.correct === "true") {
            goToNextStep(index);
          } else {
            showFeedback(question, feedbackMessageFor());
          }
        });
      });

      const desafioItem = question.querySelector("[data-desafio-item]");
      if (desafioItem) {
        const banco = desafioItem.querySelector("[data-desafio-banco]");
        const resposta = desafioItem.querySelector("[data-desafio-resposta]");
        const input = desafioItem.querySelector("[data-desafio-input]");
        const checkButton = desafioItem.querySelector("[data-check-answer]");
        const correctOrder = desafioItem.dataset.correctOrder || "";

        const sync = () => {
          const palavras = Array.from(resposta.querySelectorAll("button[data-palavra-selecionada]")).map((node) => node.dataset.value);
          input.value = palavras.join("||");
        };

        banco.querySelectorAll("[data-palavra]").forEach((button) => {
          button.addEventListener("click", () => {
            const selected = document.createElement("button");
            selected.type = "button";
            selected.dataset.palavraSelecionada = "true";
            selected.dataset.value = button.textContent.trim();
            selected.className = "btn-primary rounded-full px-4 py-3 text-base font-semibold";
            selected.style.minHeight = "48px";
            selected.textContent = button.textContent.trim();

            selected.addEventListener("click", () => {
              button.classList.remove("hidden");
              selected.remove();
              sync();
            });

            resposta.appendChild(selected);
            button.classList.add("hidden");
            sync();
          });
        });

        checkButton?.addEventListener("click", () => {
          if (!input.value.length) return;

          if (input.value === correctOrder) {
            goToNextStep(index);
          } else {
            showFeedback(question, feedbackMessageFor());
          }
        });
      }
    });

    if (timerBar && duration > 0) {
      requestAnimationFrame(() => {
        timerBar.style.transition = `width ${duration}s linear`;
        timerBar.style.width = "100%";
      });
    }

    if (tipo === "foco") {
      const imagem = root.querySelector("[data-foco-imagem]");
      const perguntasContainer = root.querySelector("[data-perguntas-container]");
      const focusTimer = root.querySelector("[data-foco-timer]");

      let remaining = duration || 10;
      if (focusTimer) focusTimer.textContent = `${remaining}s`;

      const countdown = window.setInterval(() => {
        remaining -= 1;
        if (focusTimer) focusTimer.textContent = `${Math.max(remaining, 0)}s`;

        if (remaining <= 0) {
          window.clearInterval(countdown);
          if (imagem) imagem.classList.add("hidden");
          if (perguntasContainer) perguntasContainer.classList.remove("hidden");
          showQuestion(0);
          if (timerMessage) timerMessage.textContent = "Agora escolha a melhor resposta com calma.";
        }
      }, 1000);
    }

    if (tipo === "desafio" && timerMessage && duration > 0) {
      window.setTimeout(() => {
        timerMessage.textContent = "Você já pode concluir quando quiser.";
      }, duration * 1000);
    }
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initializeMissionView);
  } else {
    initializeMissionView();
  }

  document.addEventListener("turbo:load", initializeMissionView);
</script>
