<div class="bg-app min-h-screen px-4 pt-8 pb-24">
  <div class="mb-6 flex items-center gap-3">
    <%= back_button_to(aluno_dashboard_path) %>
    <h1 class="text-primary text-xl font-bold">
      Notificações
    </h1>
  </div>

  <% if @alertas.any? %>
    <div class="mb-4">
      <p class="text-muted mb-2 text-xs font-semibold uppercase tracking-wide">Hoje</p>
      <div class="space-y-3">
        <% @alertas.each do |alerta| %>
          <div class="bg-surface shadow-soft rounded-2xl flex items-start gap-3 p-4">
            <div class="bg-app flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-full">
              <i class="fa-solid <%= alerta[:icone] %>" aria-hidden="true" style="color: <%= alerta[:cor] %>; font-size: 18px;"></i>
            </div>
            <div>
              <p class="text-primary text-sm font-semibold">
                <%= alerta[:titulo] %>
              </p>
              <p class="text-secondary mt-1 text-sm">
                <%= alerta[:mensagem] %>
              </p>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <div>
    <p class="text-muted mb-2 text-xs font-semibold uppercase tracking-wide">Recados do professor</p>

    <% if @recados.any? %>
      <div class="space-y-3">
        <% @recados.each do |recado| %>
          <div class="bg-surface shadow-soft rounded-2xl flex items-start gap-3 p-4">
            <% if recado.professor.foto.attached? %>
              <%= image_tag recado.professor.foto,
                    class: "h-10 w-10 rounded-full object-cover flex-shrink-0" %>
            <% else %>
              <div class="btn-primary flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-full text-sm font-bold text-white">
                <%= recado.professor.name.first.upcase %>
              </div>
            <% end %>
            <div class="flex-1">
              <div class="flex items-center justify-between">
                <p class="text-primary text-sm font-semibold">
                  <%= recado.professor.name %>
                </p>
                <p class="text-muted text-xs">
                  <%= recado.created_at.strftime("%d/%m") %>
                </p>
              </div>
              <p class="text-secondary mt-1 text-sm">
                <%= recado.mensagem %>
              </p>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="bg-surface shadow-soft rounded-2xl p-6 text-center">
        <i class="fa-solid fa-bell-slash text-muted mb-2 text-2xl" aria-hidden="true"></i>
        <p class="text-muted text-sm">
          Nenhum recado do professor ainda
        </p>
      </div>
    <% end %>
  </div>
</div>
