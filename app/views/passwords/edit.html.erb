<div class="min-h-screen flex flex-col items-center justify-center px-4 py-12" style="background-color: #F5F0E8;">
  <div class="w-full max-w-md rounded-2xl bg-[#EDE8DF] p-8 shadow-sm">
    <h1 class="text-2xl font-bold" style="color: #2C4A7C;"><%= t("passwords.edit.title") %></h1>
    <p class="mt-3 text-base leading-relaxed" style="color: #7A726C;">Escolha uma nova senha com no mínimo 8 caracteres.</p>

    <% if @user.errors.any? %>
      <div class="mt-5 rounded-2xl border border-[#e5ce94] bg-[#F5E9C8] px-4 py-3 text-base text-[#8a6510]">
        <ul class="space-y-1 text-sm">
          <% @user.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <%= form_with url: password_path(params[:token]), method: :put, class: "mt-5 space-y-5" do |form| %>
      <div>
        <%= form.label :password, "Nova senha", class: "block text-base font-semibold text-stone-800" %>
        <%= form.password_field :password, required: true, autocomplete: "new-password", placeholder: "Mínimo 8 caracteres", maxlength: 72, class: "mt-2 block min-h-12 w-full rounded-2xl border border-[#D9D0C4] bg-[#F5F0E8] px-4 py-3 text-base text-stone-900 outline-none focus:border-[#4A6FA5] focus:ring-2 focus:ring-[#4A6FA5]/20" %>
      </div>

      <div>
        <%= form.label :password_confirmation, "Confirmar nova senha", class: "block text-base font-semibold text-stone-800" %>
        <%= form.password_field :password_confirmation, required: true, autocomplete: "new-password", placeholder: "Repita a senha", maxlength: 72, class: "mt-2 block min-h-12 w-full rounded-2xl border border-[#D9D0C4] bg-[#F5F0E8] px-4 py-3 text-base text-stone-900 outline-none focus:border-[#4A6FA5] focus:ring-2 focus:ring-[#4A6FA5]/20" %>
      </div>

      <%= form.submit t("passwords.edit.submit"), class: "w-full rounded-full px-6 py-4 text-base font-semibold text-white cursor-pointer min-h-12", style: "background-color: #4A6FA5; border: none;" %>
    <% end %>
  </div>
</div>
