<div class="bg-app min-h-screen flex flex-col items-center justify-center px-4 py-12">
  <div class="bg-surface shadow-soft w-full max-w-md rounded-2xl p-8">
    <h1 class="text-primary text-2xl font-bold"><%= t("passwords.edit.title") %></h1>
    <p class="text-muted mt-3 text-base leading-relaxed">Escolha uma nova senha com no mínimo 8 caracteres.</p>

    <% if @user.errors.any? %>
      <div class="bg-surface-warning border-subtle text-warning mt-5 rounded-2xl border px-4 py-3 text-base">
        <ul class="space-y-1 text-sm">
          <% @user.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <%= form_with url: password_path(params[:token]), method: :put, class: "mt-5 space-y-5" do |form| %>
      <div>
        <%= form.label :password, "Nova senha", class: "text-primary block text-base font-semibold" %>
        <%= form.password_field :password, required: true, autocomplete: "new-password", placeholder: "Mínimo 8 caracteres", maxlength: 72, class: "form-input-theme mt-2 block min-h-12 w-full rounded-2xl px-4 py-3 text-base" %>
      </div>

      <div>
        <%= form.label :password_confirmation, "Confirmar nova senha", class: "text-primary block text-base font-semibold" %>
        <%= form.password_field :password_confirmation, required: true, autocomplete: "new-password", placeholder: "Repita a senha", maxlength: 72, class: "form-input-theme mt-2 block min-h-12 w-full rounded-2xl px-4 py-3 text-base" %>
      </div>

      <%= form.submit t("passwords.edit.submit"), class: "btn-primary min-h-12 w-full rounded-full px-6 py-4 text-base font-semibold cursor-pointer" %>
    <% end %>
  </div>
</div>
