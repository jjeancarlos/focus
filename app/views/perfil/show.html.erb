<div class="bg-app min-h-screen px-4 pt-8 pb-24">
  <%= form_with model: @user, url: perfil_path, method: :patch,
        local: true, class: "space-y-5" do |form| %>
    <div class="mb-6 flex flex-col items-center">
      <div class="relative">
        <% if @user.foto.attached? %>
          <%= image_tag @user.foto,
                class: "rounded-full object-cover",
                style: "width: 100px; height: 100px;" %>
        <% else %>
          <div class="btn-primary flex items-center justify-center rounded-full text-3xl font-bold text-white"
               style="width: 100px; height: 100px;">
            <%= @user.name.first.upcase %>
          </div>
        <% end %>

        <label for="foto-input"
               class="absolute bottom-0 right-0 flex items-center justify-center rounded-full cursor-pointer text-sm font-bold text-white"
               style="width: 32px; height: 32px; background-color: var(--action-primary-strong);">
          <i class="fa-solid fa-pen" aria-hidden="true"></i>
        </label>
        <%= form.file_field :foto,
              id: "foto-input",
              accept: "image/*",
              class: "hidden",
              onchange: "this.form.submit()" %>
      </div>

      <p class="text-primary mt-3 text-lg font-bold">
        <%= @user.name %>
      </p>
      <p class="text-muted text-sm">
        <%= @user.email_address %>
      </p>
    </div>

    <div class="bg-surface shadow-soft rounded-2xl p-4">
      <%= form.label :name, "Nome completo",
            class: "text-muted mb-2 block text-sm font-semibold" %>
      <%= form.text_field :name,
            class: "form-input-theme w-full rounded-xl px-4 py-3 text-base" %>
    </div>

    <div class="bg-surface shadow-soft rounded-2xl p-4">
      <%= form.label :email_address, "Email",
            class: "text-muted mb-2 block text-sm font-semibold" %>
      <%= form.email_field :email_address,
            class: "form-input-theme w-full rounded-xl px-4 py-3 text-base" %>
    </div>

    <% if @user.aluno? %>
      <div class="bg-surface shadow-soft rounded-2xl p-4">
        <p class="text-muted mb-2 text-sm font-semibold">
          Perfil de acessibilidade
        </p>
        <% perfil = @user.perfil_acessibilidade %>
        <% if perfil.present? %>
          <span class="btn-primary inline-block rounded-full px-4 py-2 text-sm font-semibold text-white">
            <%= accessibility_profile_badge(perfil) %>
          </span>
        <% else %>
          <p class="text-muted text-sm">Não definido</p>
        <% end %>
      </div>

      <div class="bg-surface shadow-soft rounded-2xl p-4">
        <p class="text-muted mb-1 text-sm font-semibold">
          Nível e XP
        </p>
        <p class="text-primary text-base font-bold">
          Nível <%= @user.nivel %> · <%= @user.xp_total %> XP
        </p>
      </div>
    <% end %>

    <%= form.submit "Salvar alterações",
          class: "btn-primary min-h-12 w-full rounded-full px-6 py-4 text-base font-semibold cursor-pointer transition-colors" %>
  <% end %>

  <% if @user.aluno? %>
    <div class="bg-surface shadow-soft mt-5 rounded-2xl p-4">
      <p class="text-muted mb-3 text-sm font-semibold">Turma</p>
      <% if @user.turma.present? %>
        <p class="text-primary text-base font-bold"><%= @user.turma.nome %></p>
        <p class="text-muted mt-1 text-sm">Você já está em uma turma.</p>
        <div class="mt-3">
          <%= turma_code_badge(@user.turma) %>
        </div>
      <% else %>
        <p class="text-muted mb-3 text-sm leading-relaxed">Digite o código do professor para entrar em uma turma.</p>
        <%= form_with url: perfil_turma_path, method: :patch, local: true, class: "space-y-3" do |turma_form| %>
          <%= turma_form.text_field :invite_token,
                name: :invite_token,
                placeholder: "Ex: FOCO2026",
                class: "form-input-theme w-full rounded-xl px-4 py-3 text-center text-base font-bold uppercase tracking-widest" %>
          <%= turma_form.submit "Entrar na turma",
                class: "btn-primary min-h-12 w-full rounded-full px-6 py-4 text-base font-semibold cursor-pointer transition-colors" %>
        <% end %>
      <% end %>
    </div>
  <% end %>

  <button type="button"
          class="btn-secondary min-h-12 mt-4 w-full rounded-full px-6 py-4 text-base font-semibold cursor-pointer"
          data-confirm-modal-open
          data-confirm-title="Sair da conta?"
          data-confirm-message="Você precisará fazer login novamente para acessar sua conta."
          data-confirm-action="<%= session_path %>"
          data-confirm-method="delete"
          data-confirm-button="Sair"
          data-confirm-icon="logout">
    Sair da conta
  </button>

  <%= render "layouts/confirm_modal" %>
</div>
