<div class="bg-app min-h-screen px-4 pt-8 pb-24">
  <div class="mb-6">
    <h1 class="text-primary text-2xl font-bold">
      Olá, <%= Current.user.name.split.first %>! <i class="fa-solid fa-hand" aria-hidden="true"></i>
    </h1>
    <p class="text-muted mt-1 text-sm">
      Painel do professor
    </p>
  </div>

  <div class="mb-6 grid grid-cols-2 gap-3">
    <div class="bg-surface shadow-soft rounded-2xl p-4 text-center">
      <p class="text-primary text-3xl font-bold">
        <%= @total_alunos %>
      </p>
      <p class="text-muted mt-1 text-xs">alunos no total</p>
    </div>
    <div class="bg-surface shadow-soft rounded-2xl p-4 text-center">
      <p class="text-accent text-3xl font-bold">
        <%= @missoes_hoje %>
      </p>
      <p class="text-muted mt-1 text-xs">missões hoje</p>
    </div>
  </div>

  <div class="mb-6">
    <div class="mb-3 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
      <p class="text-muted text-sm font-semibold">
        <i class="fa-solid fa-school" aria-hidden="true"></i> Minhas turmas
      </p>
      <%= link_to new_professor_turma_path,
            class: "btn-primary inline-flex min-h-12 items-center justify-center rounded-full px-4 py-2 text-sm font-semibold transition-colors" do %>
        <i class="fa-solid fa-plus" aria-hidden="true"></i>
        <span class="ml-2">Nova turma</span>
      <% end %>
    </div>

    <div class="border-subtle bg-app mb-4 rounded-2xl border p-4">
      <%= form_with url: professor_dashboard_path, method: :get, local: true, class: "space-y-3" do |form| %>
        <div class="flex items-center gap-3">
          <div class="bg-surface flex h-11 w-11 shrink-0 items-center justify-center rounded-full">
            <i class="fa-solid fa-magnifying-glass text-primary" aria-hidden="true"></i>
          </div>
          <div>
            <label for="dashboard-search" class="text-primary block text-base font-semibold">
              Buscar turma ou aluno
            </label>
            <p class="text-muted mt-1 text-sm">
              Encontre uma turma pelo nome ou localize um aluno.
            </p>
          </div>
        </div>
        <div class="flex flex-col gap-3 sm:flex-row">
          <%= form.search_field :q,
                value: @query,
                id: "dashboard-search",
                placeholder: "Nome da turma ou aluno",
                class: "form-input-theme min-h-12 w-full rounded-full px-4 py-3 text-base outline-none",
                autocomplete: "off" %>
          <div class="flex gap-3 sm:shrink-0">
            <%= form.button type: "submit", class: "btn-primary min-h-12 flex-1 rounded-full px-5 py-3 text-base font-semibold sm:flex-none" do %>
              <i class="fa-solid fa-magnifying-glass" aria-hidden="true"></i>
              <span class="ml-2">Buscar</span>
            <% end %>
            <% if @query.present? %>
              <%= link_to professor_dashboard_path,
                    class: "btn-secondary inline-flex min-h-12 flex-1 items-center justify-center rounded-full px-5 py-3 text-base font-semibold sm:flex-none" do %>
                <i class="fa-solid fa-rotate-left" aria-hidden="true"></i>
                <span class="ml-2">Limpar</span>
              <% end %>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>

    <% if @turmas.any? %>
      <div class="space-y-3">
        <% @turmas.each do |turma| %>
          <% alunos_encontrados = @alunos_encontrados_por_turma[turma] || [] %>
          <div class="bg-surface shadow-soft rounded-2xl p-5 interactive-card">
            <div class="min-w-0">
              <%= link_to professor_turma_path(turma), class: "block" do %>
                <p class="text-primary text-base font-semibold wrap-break-word">
                  <%= turma.nome %>
                </p>
                <p class="text-muted mt-1 text-sm">
                  <%= turma.alunos.size %> alunos
                </p>
              <% end %>
              <% if alunos_encontrados.any? %>
                <div class="bg-app mt-3 rounded-2xl p-3">
                  <p class="text-muted text-sm font-semibold">Alunos encontrados</p>
                  <p class="text-primary mt-2 text-base leading-relaxed wrap-break-word">
                    <%= alunos_encontrados.map(&:name).join(", ") %>
                  </p>
                </div>
              <% end %>
              <div class="mt-3">
                <%= turma_code_badge(turma) %>
              </div>
            </div>

            <div class="border-subtle mt-4 flex justify-end border-t pt-4">
              <button type="button"
                      class="icon-action-button inline-flex min-h-12 items-center justify-center rounded-full px-3 py-2 text-sm font-semibold"
                      aria-label="Excluir turma <%= turma.nome %>"
                      title="Excluir turma"
                      data-confirm-modal-open
                      data-confirm-title="Excluir turma?"
                      data-confirm-message="Os alunos serão apenas desvinculados desta turma."
                      data-confirm-action="<%= professor_turma_path(turma) %>"
                      data-confirm-method="delete"
                      data-confirm-button="Excluir turma"
                      data-confirm-icon="trash"
                      onclick="event.stopPropagation()">
                <i class="fa-solid fa-trash-alt" aria-hidden="true"></i>
              </button>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="bg-surface shadow-soft rounded-2xl p-6 text-center">
        <p class="text-muted text-base">
          <%= @query.present? ? "Nenhuma turma ou aluno encontrado" : "Nenhuma turma criada ainda" %>
        </p>
      </div>
    <% end %>

    <%= render "layouts/confirm_modal" %>
  </div>
</div>

