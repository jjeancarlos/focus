<div class="bg-app min-h-screen px-4 pt-8 pb-24">
  <div class="mb-6 space-y-4">
    <%= back_button_to(professor_turma_path(@turma)) %>
    <div>
      <h1 class="text-primary text-xl font-bold">
        <%= @aluno.name %>
      </h1>
      <p class="text-muted text-sm">
        <%= @turma.nome %> · <%= accessibility_profile_badge(@aluno.perfil_acessibilidade) %>
      </p>
    </div>
  </div>

  <%= link_to relatorio_ia_professor_turma_aluno_path(@turma, @aluno),
        id: "btn-relatorio-ia",
        class: "btn-primary mb-6 flex min-h-12 w-full items-center justify-center gap-2 rounded-2xl px-6 py-4 text-base font-semibold",
        data: { loading_report: true } do %>
    <i class="fa-solid fa-file-lines" aria-hidden="true"></i>
    Gerar Relatório com IA
  <% end %>

  <div id="report-loading-modal"
       class="hidden fixed inset-0 z-50 items-center justify-center px-6 modal-overlay-theme"
       data-modal-state="closed"
       aria-hidden="true"
       role="dialog"
       aria-modal="true">
    <div class="modal-card-theme relative overflow-hidden text-center">
      <div class="loading-modal-accent"></div>

      <div class="relative mx-auto mb-6 h-24 w-24" data-loading-report-spinner>
        <div class="loading-modal-spinner-track absolute inset-0 rounded-full border-4"></div>
        <div class="loading-modal-spinner-ring absolute inset-0 rounded-full border-4 border-t-transparent animate-spin"></div>
        <div class="absolute inset-0 flex items-center justify-center">
          <i class="fa-solid fa-file-arrow-down loading-modal-spinner-icon text-3xl animate-pulse" aria-hidden="true"></i>
        </div>
      </div>

      <h3 class="text-primary mb-2 text-xl font-bold">
        Gerando seu arquivo
      </h3>

      <p class="text-muted text-sm font-medium transition-opacity duration-500" data-loading-report-message>
        Conectando com a IA...
      </p>

      <div class="loading-modal-progress-track mt-8 h-1.5 w-full overflow-hidden rounded-full">
        <div class="loading-modal-progress-bar h-1.5 rounded-full"></div>
      </div>
    </div>
  </div>

  <div class="mb-4 grid grid-cols-3 gap-3">
    <div class="bg-surface shadow-soft rounded-2xl p-3 text-center">
      <p class="text-primary text-xl font-bold">
        <%= @aluno.nivel %>
      </p>
      <p class="text-muted mt-1 text-xs">nível</p>
    </div>
    <div class="bg-surface shadow-soft rounded-2xl p-3 text-center">
      <p class="text-accent text-xl font-bold">
        <%= @aluno.xp_total %>
      </p>
      <p class="text-muted mt-1 text-xs">XP total</p>
    </div>
    <div class="bg-surface shadow-soft rounded-2xl p-3 text-center">
      <p class="text-success text-xl font-bold">
        <%= @aluno.sequencia_dias %>
      </p>
      <p class="text-muted mt-1 text-xs">dias seguidos</p>
    </div>
  </div>

  <div class="bg-surface shadow-soft mb-4 rounded-2xl p-4">
    <p class="text-muted mb-3 text-sm font-semibold">
      <i class="fa-solid fa-chart-line" aria-hidden="true"></i> XP por dia — últimos 7 dias
    </p>
    <% if @xp_por_dia.any? %>
      <% xp_por_dia = @xp_por_dia.map do |label, valor|
           data_label = label.respond_to?(:strftime) ? label.strftime('%d/%m') : label.to_s
           [data_label, valor.to_i]
         end %>
      <% max_xp = xp_por_dia.map { |_, valor| valor }.max.to_i %>
      <% max_xp = 1 if max_xp.zero? %>
      <% svg_w_xp = 320 %>
      <% row_height_xp = 42 %>
      <% top_padding_xp = 22 %>
      <% bottom_padding_xp = 16 %>
      <% chart_left_xp = 76 %>
      <% chart_right_xp = 286 %>
      <% bar_max_w_xp = chart_right_xp - chart_left_xp %>
      <% svg_h_xp = top_padding_xp + (xp_por_dia.size * row_height_xp) + bottom_padding_xp %>
      <div class="bg-app border-subtle rounded-2xl border px-3 py-4">
        <svg width="100%" viewBox="0 0 <%= svg_w_xp %> <%= svg_h_xp %>" role="img" aria-label="Gráfico de XP por dia nos últimos 7 dias" style="display: block; margin: 0 auto; max-width: 100%;">
          <defs>
            <linearGradient id="xpProfessorGrad" x1="0" y1="0" x2="1" y2="0">
              <stop offset="0%" stop-color="var(--action-primary)"/>
              <stop offset="100%" stop-color="var(--action-primary-strong)"/>
            </linearGradient>
          </defs>
          <% xp_por_dia.each_with_index do |(label, valor), i| %>
            <% y = top_padding_xp + (i * row_height_xp) %>
            <% bar_w = [(valor / max_xp.to_f * bar_max_w_xp).round, 8].max %>
            <% opacity = 0.35 + (valor / max_xp.to_f * 0.65) %>
            <text x="16" y="<%= y + 17 %>" font-size="13" fill="var(--text-muted)"><%= label %></text>
            <rect x="<%= chart_left_xp %>" y="<%= y %>" width="<%= bar_max_w_xp %>" height="22" rx="8" fill="var(--surface-muted)"/>
            <rect x="<%= chart_left_xp %>" y="<%= y %>" width="<%= bar_w %>" height="22" rx="8" fill="url(#xpProfessorGrad)" opacity="<%= opacity.round(2) %>"/>
            <text x="<%= [chart_left_xp + bar_w + 8, chart_right_xp + 10].min %>" y="<%= y + 16 %>" font-size="13" font-weight="600" fill="var(--text-secondary)"><%= valor %></text>
          <% end %>
        </svg>
      </div>
    <% else %>
      <p class="text-muted py-4 text-center text-sm">
        <i class="fa-solid fa-seedling" aria-hidden="true"></i> Nenhuma missão esta semana
      </p>
    <% end %>
  </div>

  <div class="bg-surface shadow-soft mb-4 rounded-2xl p-4">
    <p class="text-muted mb-3 text-sm font-semibold">
      <i class="fa-solid fa-puzzle-piece" aria-hidden="true"></i> Missões por tipo — esta semana
    </p>
    <% if @missoes_por_tipo.any? %>
      <% missoes_por_tipo = [
           ["Leitura", @missoes_por_tipo["leitura"].to_i],
           ["Foco", @missoes_por_tipo["foco"].to_i],
           ["Desafio", @missoes_por_tipo["desafio"].to_i]
         ].select { |_, valor| valor.positive? } %>
      <% max_missoes_tipo = missoes_por_tipo.map { |_, valor| valor }.max.to_i %>
      <% max_missoes_tipo = 1 if max_missoes_tipo.zero? %>
      <% n_tipos = missoes_por_tipo.size %>
      <% bar_w_tipos = 44 %>
      <% spacing_tipos = 68 %>
      <% svg_w_tipos = 336 %>
      <% svg_h_tipos = 192 %>
      <% max_bar_h_tipos = 116 %>
      <% baseline_tipos = 140 %>
      <% chart_start_tipos = (svg_w_tipos / 2.0) - (((n_tipos - 1) * spacing_tipos) / 2.0) %>
      <div class="bg-app border-subtle rounded-2xl border px-3 py-4">
        <svg width="100%" viewBox="0 0 <%= svg_w_tipos %> <%= svg_h_tipos %>" role="img" aria-label="Gráfico de missões por tipo nesta semana" style="display: block; margin: 0 auto; max-width: 100%;">
          <defs>
            <linearGradient id="tiposGrad" x1="0" y1="0" x2="0" y2="1">
              <stop offset="0%" stop-color="var(--action-primary)"/>
              <stop offset="100%" stop-color="var(--action-primary-strong)"/>
            </linearGradient>
          </defs>
          <% missoes_por_tipo.each_with_index do |(label, valor), i| %>
            <% cx = chart_start_tipos + (spacing_tipos * i) %>
            <% h = [(valor / max_missoes_tipo.to_f * max_bar_h_tipos).round, 4].max %>
            <% y = baseline_tipos - h %>
            <% opacity = 0.35 + (valor / max_missoes_tipo.to_f * 0.65) %>
            <rect x="<%= cx - bar_w_tipos / 2 %>" y="<%= y %>" width="<%= bar_w_tipos %>" height="<%= h %>" rx="8" fill="url(#tiposGrad)" opacity="<%= opacity.round(2) %>"/>
            <text x="<%= cx %>" y="<%= y - 9 %>" text-anchor="middle" font-size="14" font-weight="600" fill="var(--text-secondary)"><%= valor %></text>
            <text x="<%= cx %>" y="168" text-anchor="middle" font-size="13" fill="var(--text-muted)"><%= label %></text>
          <% end %>
        </svg>
      </div>
    <% else %>
      <p class="text-muted py-4 text-center text-sm">
        <i class="fa-solid fa-seedling" aria-hidden="true"></i> Nenhuma missão esta semana
      </p>
    <% end %>
  </div>

  <div class="bg-surface shadow-soft rounded-2xl">
    <div class="px-4 pt-4 pb-2">
      <p class="text-muted text-sm font-semibold">
        <i class="fa-solid fa-clipboard-list" aria-hidden="true"></i> Missões recentes
      </p>
    </div>
    <% tentativas = @aluno.tentativas.order(concluida_em: :desc).limit(5) %>
    <% if tentativas.any? %>
      <% tentativas.each do |t| %>
        <div class="border-subtle flex items-center justify-between border-t px-4 py-3">
          <div>
            <p class="text-primary text-sm font-semibold">
              <%= case t.tipo_missao
                  when "leitura" then raw('<i class="fa-solid fa-book-open" aria-hidden="true"></i> Leitura Guiada')
                  when "foco"    then raw('<i class="fa-solid fa-bullseye" aria-hidden="true"></i> Missão de Foco')
                  when "desafio" then raw('<i class="fa-solid fa-puzzle-piece" aria-hidden="true"></i> Desafio')
                  end %>
            </p>
            <p class="text-muted text-xs">
              <%= t.concluida_em.strftime("%d/%m às %H:%M") %>
            </p>
          </div>
          <span class="text-success text-sm font-bold">
            +<%= t.xp_ganho %> XP
          </span>
        </div>
      <% end %>
    <% else %>
      <p class="text-muted px-4 py-6 text-center text-sm">
        Nenhuma missão registrada ainda
      </p>
    <% end %>
  </div>

  <div class="bg-surface shadow-soft mt-5 rounded-2xl p-4">
    <p class="text-muted mb-3 text-sm font-semibold">
      <i class="fa-solid fa-envelope" aria-hidden="true"></i> Enviar recado para o aluno
    </p>
    <%= form_with scope: :recado, url: professor_recados_path, method: :post, local: true do |form| %>
      <%= form.hidden_field :aluno_id, value: @aluno.id %>
      <%= form.text_area :mensagem,
            placeholder: "Escreva uma mensagem de incentivo...",
            rows: 3,
            class: "form-input-theme w-full resize-none rounded-xl px-4 py-3 text-base outline-none" %>
      <button type="submit"
              class="btn-primary min-h-12 mt-3 w-full rounded-full px-6 py-3 text-base font-semibold cursor-pointer">
        <i class="fa-solid fa-paper-plane" aria-hidden="true"></i>
        Enviar recado
      </button>
    <% end %>
  </div>
</div>