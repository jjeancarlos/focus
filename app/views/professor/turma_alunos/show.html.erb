<div class="min-h-screen pb-24 px-4 pt-8"
     style="background-color: #F5F0E8;">

  <%# HEADER %>
  <div class="space-y-4 mb-6">
    <%= back_button_to(professor_turma_path(@turma)) %>
    <div>
      <h1 class="text-xl font-bold" style="color: #2C4A7C;">
        <%= @aluno.name %>
      </h1>
      <p class="text-sm" style="color: #7A726C;">
        <%= @turma.nome %> · <%= accessibility_profile_badge(@aluno.perfil_acessibilidade) %>
      </p>
    </div>
  </div>

  <%# BOTÃO RELATÓRIO IA %>
  <%= link_to relatorio_ia_professor_turma_aluno_path(@turma, @aluno),
        id: "btn-relatorio-ia",
        class: "flex items-center justify-center gap-2 w-full rounded-2xl px-6 py-4 mb-6 font-semibold text-white shadow-sm",
        style: "background-color: #2C4A7C;" do %>
    <i class="fa-solid fa-file-lines" aria-hidden="true"></i>
    Gerar Relatório com IA
  <% end %>

  <%# KPIs DO ALUNO %>
  <div class="grid grid-cols-3 gap-3 mb-4">
    <div class="rounded-2xl p-3 text-center shadow-sm"
         style="background-color: #EDE8DF;">
      <p class="text-xl font-bold" style="color: #2C4A7C;">
        <%= @aluno.nivel %>
      </p>
      <p class="text-xs mt-1" style="color: #7A726C;">nível</p>
    </div>
    <div class="rounded-2xl p-3 text-center shadow-sm"
         style="background-color: #EDE8DF;">
      <p class="text-xl font-bold" style="color: #4A6FA5;">
        <%= @aluno.xp_total %>
      </p>
      <p class="text-xs mt-1" style="color: #7A726C;">XP total</p>
    </div>
    <div class="rounded-2xl p-3 text-center shadow-sm"
         style="background-color: #EDE8DF;">
      <p class="text-xl font-bold" style="color: #4A8C5C;">
        <%= @aluno.sequencia_dias %>
      </p>
      <p class="text-xs mt-1" style="color: #7A726C;">dias seguidos</p>
    </div>
  </div>

  <%# GRÁFICO XP POR DIA %>
  <div class="rounded-2xl p-4 mb-4 shadow-sm"
       style="background-color: #EDE8DF;">
    <p class="text-sm font-semibold mb-3" style="color: #7A726C;">
      <i class="fa-solid fa-chart-line" aria-hidden="true"></i> XP por dia — últimos 7 dias
    </p>
    <% if @xp_por_dia.any? %>
      <%= bar_chart @xp_por_dia,
            colors: ["#4A6FA5"],
            height: "140px",
            library: {
              plugins: { legend: { display: false } },
              scales: {
                x: { grid: { display: false },
                     ticks: { color: "#7A726C", font: { size: 10 } } },
                y: { grid: { color: "#D4E0F0" },
                     ticks: { color: "#7A726C", font: { size: 10 } },
                     beginAtZero: true }
              }
            } %>
    <% else %>
      <p class="text-sm text-center py-4" style="color: #7A726C;">
        <i class="fa-solid fa-seedling" aria-hidden="true"></i> Nenhuma missão esta semana
      </p>
    <% end %>
  </div>

  <%# MISSÕES POR TIPO %>
  <div class="rounded-2xl p-4 mb-4 shadow-sm"
       style="background-color: #EDE8DF;">
    <p class="text-sm font-semibold mb-3" style="color: #7A726C;">
      <i class="fa-solid fa-puzzle-piece" aria-hidden="true"></i> Missões por tipo — esta semana
    </p>
    <% if @missoes_por_tipo.any? %>
      <%= pie_chart @missoes_por_tipo,
            colors: ["#4A6FA5", "#4A8C5C", "#9C7A2E"],
            height: "160px",
            library: {
              plugins: {
                legend: {
                  position: "bottom",
                  labels: { color: "#4A4540", font: { size: 11 }, padding: 12 }
                }
              }
            } %>
    <% else %>
      <p class="text-sm text-center py-4" style="color: #7A726C;">
        <i class="fa-solid fa-seedling" aria-hidden="true"></i> Nenhuma missão esta semana
      </p>
    <% end %>
  </div>

  <%# MISSÕES RECENTES %>
  <div class="rounded-2xl shadow-sm" style="background-color: #EDE8DF;">
    <div class="px-4 pt-4 pb-2">
      <p class="text-sm font-semibold" style="color: #7A726C;">
        <i class="fa-solid fa-clipboard-list" aria-hidden="true"></i> Missões recentes
      </p>
    </div>
    <% tentativas = @aluno.tentativas.order(concluida_em: :desc).limit(5) %>
    <% if tentativas.any? %>
      <% tentativas.each do |t| %>
        <div class="flex items-center justify-between px-4 py-3 border-t"
             style="border-color: #D9D0C4;">
          <div>
            <p class="text-sm font-semibold" style="color: #2A2520;">
              <%= case t.tipo_missao
                  when "leitura" then raw('<i class="fa-solid fa-book-open" aria-hidden="true"></i> Leitura Guiada')
                  when "foco"    then raw('<i class="fa-solid fa-bullseye" aria-hidden="true"></i> Missão de Foco')
                  when "desafio" then raw('<i class="fa-solid fa-puzzle-piece" aria-hidden="true"></i> Desafio')
                  end %>
            </p>
            <p class="text-xs" style="color: #7A726C;">
              <%= t.concluida_em.strftime("%d/%m às %H:%M") %>
            </p>
          </div>
          <span class="text-sm font-bold" style="color: #4A8C5C;">
            +<%= t.xp_ganho %> XP
          </span>
        </div>
      <% end %>
    <% else %>
      <p class="text-sm text-center py-6 px-4" style="color: #7A726C;">
        Nenhuma missão registrada ainda
      </p>
    <% end %>
  </div>

  <div class="mt-5 rounded-2xl p-4 shadow-sm" style="background-color: #EDE8DF;">
    <p class="text-sm font-semibold mb-3" style="color: #7A726C;">
      <i class="fa-solid fa-envelope" aria-hidden="true"></i> Enviar recado para o aluno
    </p>
    <%= form_with scope: :recado, url: professor_recados_path, method: :post, local: true do |form| %>
      <%= form.hidden_field :aluno_id, value: @aluno.id %>
      <%= form.text_area :mensagem,
            placeholder: "Escreva uma mensagem de incentivo...",
            rows: 3,
            class: "w-full rounded-xl px-4 py-3 text-base outline-none resize-none",
            style: "background-color: #F5F0E8; border: 1.5px solid #D9D0C4; color: #2A2520; font-size: 16px;" %>
      <button type="submit"
              class="mt-3 w-full rounded-full px-6 py-3 text-base font-semibold text-white cursor-pointer min-h-12"
              style="background-color: #4A6FA5; border: none;">
        <i class="fa-solid fa-paper-plane" aria-hidden="true"></i>
        Enviar recado
      </button>
    <% end %>
  </div>
</div>