<div class="bg-app min-h-screen flex flex-col items-center justify-center px-4 py-12">
  <div class="mb-8 text-center">
    <h1 class="text-primary text-2xl font-bold">
      Nova turma
    </h1>
    <p class="text-muted mt-3 text-base leading-relaxed">
      O código de convite será gerado automaticamente
    </p>
  </div>

  <div class="bg-surface shadow-soft w-full max-w-md rounded-2xl p-8">
    <%= form_with model: @turma, url: professor_turmas_path,
          local: true, class: "space-y-5" do |form| %>
      <div>
        <%= form.label :nome, "Nome da turma",
              class: "text-primary block text-base font-semibold" %>
        <%= form.text_field :nome,
              required: true,
              autofocus: true,
              placeholder: "Ex: 3º Ano B — 2026",
              class: "form-input-theme mt-2 block min-h-12 w-full rounded-2xl px-4 py-3 text-base" %>
      </div>

      <div class="space-y-3 pt-2">
        <%= form.submit "Criar turma",
              class: "btn-primary min-h-12 w-full rounded-full px-6 py-3 text-base font-semibold cursor-pointer transition-colors" %>
        <div class="flex justify-center">
          <%= back_button_to(professor_dashboard_path) %>
        </div>
      </div>
    <% end %>
  </div>
</div>
