<div class="min-h-screen flex flex-col items-center justify-center px-4 py-12"
     style="background-color: #F5F0E8;">

  <div class="mb-8 text-center">
    <h1 class="text-2xl font-bold text-[#2C4A7C]">
      Nova turma
    </h1>
    <p class="mt-3 text-base leading-relaxed text-[#7A726C]">
      O código de convite será gerado automaticamente
    </p>
  </div>

  <div class="w-full max-w-md rounded-2xl bg-[#EDE8DF] p-8 shadow-sm">

    <%= form_with model: @turma, url: professor_turmas_path,
          local: true, class: "space-y-5" do |form| %>

      <div>
        <%= form.label :nome, "Nome da turma",
              class: "block text-base font-semibold text-stone-800" %>
        <%= form.text_field :nome,
              required: true,
              autofocus: true,
              placeholder: "Ex: 3º Ano B — 2026",
              class: "mt-2 block min-h-12 w-full rounded-2xl border
                      border-[#D9D0C4] bg-[#F5F0E8] px-4 py-3 text-base
                      text-stone-900 outline-none focus:border-[#4A6FA5]
                      focus:ring-2 focus:ring-[#4A6FA5]/20" %>
      </div>

      <div class="space-y-3 pt-2">
        <%= form.submit "Criar turma 🏫",
              class: "min-h-12 w-full rounded-full bg-[#4A6FA5] px-6
                      py-3 text-base font-semibold text-white cursor-pointer" %>
        <div class="flex justify-center">
          <%= back_button_to(professor_dashboard_path) %>
        </div>
      </div>

    <% end %>
  </div>
</div>