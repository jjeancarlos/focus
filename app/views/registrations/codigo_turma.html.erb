<div class="bg-app min-h-screen flex flex-col items-center justify-center px-4 py-12">
  <div class="mb-8 text-center">
    <h1 class="text-primary text-2xl font-bold">
      Você tem um código de turma?
    </h1>
    <p class="text-muted mt-3 text-base leading-relaxed">
      Digite o código do seu professor para entrar na turma
    </p>
  </div>

  <div class="bg-surface shadow-soft w-full max-w-md rounded-2xl p-8">
    <% if alert.present? %>
      <div class="bg-surface-warning text-warning mb-5 rounded-xl px-4 py-3 text-sm font-medium">
        <%= alert %>
      </div>
    <% end %>

    <%= form_with url: cadastro_turma_path, method: :post,
          local: true, class: "space-y-5" do |form| %>
      <div>
        <%= label_tag :invite_token, "Código da turma",
              class: "text-primary block text-base font-semibold" %>
        <%= text_field_tag :invite_token, nil,
              placeholder: "Ex: FOCO2026",
              autofocus: true,
              class: "form-input-theme mt-2 block min-h-12 w-full rounded-2xl px-4 py-3 text-center text-base text-lg font-bold uppercase tracking-widest" %>
      </div>

      <div class="space-y-3 pt-2">
        <button type="submit"
                class="btn-primary min-h-12 w-full rounded-full px-6 py-3 text-base font-semibold cursor-pointer transition-colors">
          <i class="fa-solid fa-graduation-cap" aria-hidden="true"></i>
          Entrar na turma
        </button>
      </div>
    <% end %>

    <%= button_to cadastro_pular_path,
          method: :post,
          class: "text-muted mt-3 w-full rounded-full px-6 py-3 text-base font-semibold cursor-pointer" do %>
      Pular por agora <i class="fa-solid fa-arrow-right" aria-hidden="true"></i>
    <% end %>
  </div>
</div>
