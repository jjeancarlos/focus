<div class="min-h-screen flex flex-col items-center justify-center px-4 py-12"
     style="background-color: #F5F0E8;">

  <div class="mb-8 text-center">
    <h1 class="text-2xl font-bold text-[#2C4A7C]">
      Você tem um código de turma?
    </h1>
    <p class="mt-3 text-base leading-relaxed text-[#7A726C]">
      Digite o código do seu professor para entrar na turma
    </p>
  </div>

  <div class="w-full max-w-md rounded-2xl bg-[#EDE8DF] p-8 shadow-sm">
    <% if alert.present? %>
      <div class="mb-5 rounded-xl px-4 py-3 text-sm font-medium"
           style="background-color: #F5E9C8; color: #2A2520;">
        <%= alert %>
      </div>
    <% end %>

    <%= form_with url: cadastro_turma_path, method: :post,
          local: true, class: "space-y-5" do |form| %>
      <div>
        <%= label_tag :invite_token, "Código da turma",
              class: "block text-base font-semibold text-stone-800" %>
        <%= text_field_tag :invite_token, nil,
              placeholder: "Ex: FOCO2026",
              autofocus: true,
              class: "mt-2 block min-h-12 w-full rounded-2xl border
                      border-[#D9D0C4] bg-[#F5F0E8] px-4 py-3 text-base
                      text-stone-900 outline-none focus:border-[#4A6FA5]
                      focus:ring-2 focus:ring-[#4A6FA5]/20 uppercase
                      tracking-widest text-center text-lg font-bold" %>
      </div>

      <div class="space-y-3 pt-2">
        <button type="submit"
                class="min-h-12 w-full rounded-full bg-[#4A6FA5] px-6
                       py-3 text-base font-semibold text-white cursor-pointer">
          <i class="fa-solid fa-graduation-cap" aria-hidden="true"></i>
          Entrar na turma
        </button>
      </div>
    <% end %>

    <%= button_to cadastro_pular_path,
          method: :post,
          class: "mt-3 w-full rounded-full px-6 py-3 text-base font-semibold cursor-pointer",
          style: "background-color: transparent; color: #7A726C; border: none;" do %>
      Pular por agora <i class="fa-solid fa-arrow-right" aria-hidden="true"></i>
    <% end %>
  </div>
</div>
