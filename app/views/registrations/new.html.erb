<div class="min-h-screen flex flex-col items-center justify-center px-4 py-12"
     style="background-color: #F5F0E8;">

  <div class="mb-8 text-center">
    <%= image_tag "focus_logo1.png", alt: "Focus", class: "mx-auto h-24 w-auto" %>
    <p class="mt-3 text-base leading-relaxed text-[#7A726C]">
      Crie sua conta e comece sua jornada
    </p>
  </div>

  <div class="w-full max-w-md rounded-2xl bg-[#EDE8DF] p-8 shadow-sm">
    <% if @user.errors.any? %>
      <div class="mb-5 rounded-2xl border border-[#e5ce94] bg-[#F5E9C8] px-4 py-3 text-base text-[#8a6510]">
        <p class="font-semibold"><%= t("auth.registration.invalid") %></p>
        <ul class="mt-2 space-y-1 text-sm">
          <% @user.errors.each do |error| %>
            <% if error.attribute == :email_address && error.type == :taken %>
              <li>
                Esse email já está cadastrado. Tente
                <%= link_to t("auth.registration.login_link"), new_session_path, class: "font-semibold underline underline-offset-2" %>.
              </li>
            <% else %>
              <li><%= @user.errors.full_message(error.attribute, error.message) %></li>
            <% end %>
          <% end %>
        </ul>
      </div>
    <% end %>

    <%= form_with model: @user, url: cadastro_path, local: true, class: "space-y-5" do |form| %>
      <div>
        <%= form.label :name, "Nome completo", class: "block text-base font-semibold text-stone-800" %>
        <%= form.text_field :name,
              required: true,
              autofocus: true,
              autocomplete: "name",
              placeholder: "Seu nome",
              class: "mt-2 block min-h-12 w-full rounded-2xl border border-[#D9D0C4] bg-[#F5F0E8] px-4 py-3 text-base text-stone-900 outline-none focus:border-[#4A6FA5] focus:ring-2 focus:ring-[#4A6FA5]/20" %>
      </div>

      <div>
        <%= form.label :email_address, "E-mail", class: "block text-base font-semibold text-stone-800" %>
        <%= form.email_field :email_address,
              required: true,
              autocomplete: "email",
              placeholder: "seu@email.com",
              class: "mt-2 block min-h-12 w-full rounded-2xl border border-[#D9D0C4] bg-[#F5F0E8] px-4 py-3 text-base text-stone-900 outline-none focus:border-[#4A6FA5] focus:ring-2 focus:ring-[#4A6FA5]/20" %>
      </div>

      <div>
        <%= form.label :password, "Senha", class: "block text-base font-semibold text-stone-800" %>
        <%= form.password_field :password,
              required: true,
              autocomplete: "new-password",
              placeholder: "Mínimo 8 caracteres",
              class: "mt-2 block min-h-12 w-full rounded-2xl border border-[#D9D0C4] bg-[#F5F0E8] px-4 py-3 text-base text-stone-900 outline-none focus:border-[#4A6FA5] focus:ring-2 focus:ring-[#4A6FA5]/20" %>
      </div>

      <div>
        <%= form.label :password_confirmation, "Confirmar senha", class: "block text-base font-semibold text-stone-800" %>
        <%= form.password_field :password_confirmation,
              required: true,
              autocomplete: "new-password",
              placeholder: "Repita a senha",
              class: "mt-2 block min-h-12 w-full rounded-2xl border border-[#D9D0C4] bg-[#F5F0E8] px-4 py-3 text-base text-stone-900 outline-none focus:border-[#4A6FA5] focus:ring-2 focus:ring-[#4A6FA5]/20" %>
      </div>

      <div class="space-y-4 pt-2">
        <%= form.submit "Continuar",
              class: "min-h-12 w-full rounded-full bg-[#4A6FA5] px-6 py-3 text-base font-semibold text-white cursor-pointer" %>
        <div class="text-center">
          Já tem conta?
          <%= link_to "Entrar", new_session_path, class: "text-base font-semibold text-[#4A6FA5]" %>
        </div>
      </div>
    <% end %>
  </div>
</div>
