<section class="mx-auto flex w-full max-w-md flex-col items-center justify-center py-6">
  <div class="mb-8 text-center">
    <h1 class="text-4xl font-bold text-[#2C4A7C]">Focus</h1>
    <p class="mt-3 text-base leading-relaxed text-[#7A726C]">
      Transformando a Educação com Tecnologia e Inclusão
    </p>
  </div>

  <div class="w-full rounded-2xl bg-[#EDE8DF] p-8 shadow-sm">
    <% if @user.errors.any? %>
      <div class="mb-5 rounded-2xl border border-[#e5ce94] bg-[#F5E9C8] px-4 py-3 text-base text-[#8a6510]">
        <p class="font-semibold">Quase lá! Revise os campos para continuar.</p>
        <ul class="mt-2 space-y-1 text-sm">
          <% @user.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <%= form_with model: @user, url: cadastro_path, class: "space-y-5" do |form| %>
      <div>
        <%= form.label :name, "Nome completo", class: "block text-base font-semibold text-stone-800" %>
        <%= form.text_field :name, required: true, autocomplete: "name", class: "mt-2 block min-h-12 w-full rounded-2xl border border-[#D9D0C4] bg-[#F5F0E8] px-4 py-3 text-base text-stone-900 outline-none focus:border-[#4A6FA5] focus:ring-2 focus:ring-[#4A6FA5]/20" %>
      </div>

      <div>
        <%= form.label :email_address, "E-mail", class: "block text-base font-semibold text-stone-800" %>
        <%= form.email_field :email_address, required: true, autocomplete: "email", class: "mt-2 block min-h-12 w-full rounded-2xl border border-[#D9D0C4] bg-[#F5F0E8] px-4 py-3 text-base text-stone-900 outline-none focus:border-[#4A6FA5] focus:ring-2 focus:ring-[#4A6FA5]/20" %>
      </div>

      <div>
        <%= form.label :password, "Senha", class: "block text-base font-semibold text-stone-800" %>
        <%= form.password_field :password, required: true, autocomplete: "new-password", maxlength: 72, class: "mt-2 block min-h-12 w-full rounded-2xl border border-[#D9D0C4] bg-[#F5F0E8] px-4 py-3 text-base text-stone-900 outline-none focus:border-[#4A6FA5] focus:ring-2 focus:ring-[#4A6FA5]/20" %>
      </div>

      <div>
        <%= form.label :password_confirmation, "Confirmar senha", class: "block text-base font-semibold text-stone-800" %>
        <%= form.password_field :password_confirmation, required: true, autocomplete: "new-password", maxlength: 72, class: "mt-2 block min-h-12 w-full rounded-2xl border border-[#D9D0C4] bg-[#F5F0E8] px-4 py-3 text-base text-stone-900 outline-none focus:border-[#4A6FA5] focus:ring-2 focus:ring-[#4A6FA5]/20" %>
      </div>

      <%= form.submit "Continuar", class: "min-h-12 w-full rounded-full bg-[#4A6FA5] px-6 py-3 text-base font-semibold text-white" %>
    <% end %>
  </div>
</section>
