<div class="bg-app min-h-screen flex flex-col items-center justify-center px-4 py-12">
  <div class="mb-8 text-center">
    <%= image_tag "focus_logo1.png", alt: "Focus", class: "mx-auto h-24 w-auto" %>
    <p class="text-muted mt-3 text-base leading-relaxed">
      Crie sua conta e comece sua jornada
    </p>
  </div>

  <div class="bg-surface shadow-soft w-full max-w-md rounded-2xl p-8">
    <% if @user.errors.any? %>
      <div class="bg-surface-warning border-subtle text-warning mb-5 rounded-2xl border px-4 py-3 text-base">
        <p class="font-semibold"><%= t("auth.registration.invalid") %></p>
        <ul class="mt-2 space-y-1 text-sm">
          <% @user.errors.each do |error| %>
            <% if error.attribute == :email_address && error.type == :taken %>
              <li>
                Esse email já está cadastrado. Tente
                <%= link_to t("auth.registration.login_link"), new_session_path, class: "font-semibold underline underline-offset-2" %>.
              </li>
            <% else %>
              <li><%= @user.errors.full_message(error.attribute, error.message) %></li>
            <% end %>
          <% end %>
        </ul>
      </div>
    <% end %>

    <%= form_with model: @user, url: cadastro_path, local: true, class: "space-y-5" do |form| %>
      <div>
        <%= form.label :name, "Nome completo", class: "text-primary block text-base font-semibold" %>
        <%= form.text_field :name,
              required: true,
              autofocus: true,
              autocomplete: "name",
              placeholder: "Seu nome",
              class: "form-input-theme mt-2 block min-h-12 w-full rounded-2xl px-4 py-3 text-base" %>
      </div>

      <div>
        <%= form.label :email_address, "E-mail", class: "text-primary block text-base font-semibold" %>
        <%= form.email_field :email_address,
              required: true,
              autocomplete: "email",
              placeholder: "seu@email.com",
              class: "form-input-theme mt-2 block min-h-12 w-full rounded-2xl px-4 py-3 text-base" %>
      </div>

      <div>
        <%= form.label :password, "Senha", class: "text-primary block text-base font-semibold" %>
        <%= form.password_field :password,
              required: true,
              autocomplete: "new-password",
              placeholder: "Mínimo 8 caracteres",
              class: "form-input-theme mt-2 block min-h-12 w-full rounded-2xl px-4 py-3 text-base" %>
      </div>

      <div>
        <%= form.label :password_confirmation, "Confirmar senha", class: "text-primary block text-base font-semibold" %>
        <%= form.password_field :password_confirmation,
              required: true,
              autocomplete: "new-password",
              placeholder: "Repita a senha",
              class: "form-input-theme mt-2 block min-h-12 w-full rounded-2xl px-4 py-3 text-base" %>
      </div>

      <div class="space-y-4 pt-2">
        <%= form.submit "Continuar",
              class: "btn-primary min-h-12 w-full rounded-full px-6 py-3 text-base font-semibold cursor-pointer transition-colors" %>
        <div class="text-muted text-center">
          Já tem conta?
          <%= link_to "Entrar", new_session_path, class: "text-accent text-base font-semibold" %>
        </div>
      </div>
    <% end %>
  </div>
</div>
