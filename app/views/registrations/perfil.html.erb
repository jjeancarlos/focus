<div class="bg-app min-h-screen flex flex-col items-center justify-center px-4 py-12">
  <div class="mb-8 text-center">
    <h1 class="text-primary text-2xl font-bold">Como você aprende?</h1>
    <p class="text-muted mt-3 text-base leading-relaxed">
      Isso nos ajuda a adaptar sua experiência
    </p>
  </div>

  <div class="w-full max-w-md">
    <% if alert.present? || @user.errors.any? %>
      <div class="bg-surface-warning border-subtle text-warning mb-5 rounded-2xl border px-4 py-3 text-base">
        <p class="font-semibold"><%= alert.presence || t("auth.registration.profile_invalid") %></p>
      </div>
    <% end %>

    <%= form_with model: @user, url: cadastro_perfil_path, method: :patch, local: true, class: "space-y-4", data: { profile_form: true } do |form| %>
      <div>
        <%= form.radio_button :perfil_acessibilidade, "dislexia", class: "peer sr-only", required: true, data: { profile_option: true } %>
        <%= form.label :perfil_acessibilidade_dislexia, class: "bg-surface border-subtle flex min-h-20 cursor-pointer items-center gap-4 rounded-2xl border p-5", data: { profile_card: true } do %>
          <span class="bg-surface-muted text-accent flex h-12 w-12 items-center justify-center rounded-full text-2xl"><i class="fa-solid fa-book-open" aria-hidden="true"></i></span>
          <span>
            <span class="text-primary block text-base font-semibold">Tenho dislexia</span>
            <span class="text-secondary mt-1 block text-sm leading-relaxed">Adapta fonte, espaçamento e tempo de leitura</span>
          </span>
        <% end %>
      </div>

      <div>
        <%= form.radio_button :perfil_acessibilidade, "tdh", class: "peer sr-only", required: true, data: { profile_option: true } %>
        <%= form.label :perfil_acessibilidade_tdh, class: "bg-surface border-subtle flex min-h-20 cursor-pointer items-center gap-4 rounded-2xl border p-5", data: { profile_card: true } do %>
          <span class="bg-surface-muted text-accent flex h-12 w-12 items-center justify-center rounded-full text-2xl"><i class="fa-solid fa-bullseye" aria-hidden="true"></i></span>
          <span>
            <span class="text-primary block text-base font-semibold">Tenho TDH</span>
            <span class="text-secondary mt-1 block text-sm leading-relaxed">Adapta temporizadores e foco visual</span>
          </span>
        <% end %>
      </div>

      <div>
        <%= form.radio_button :perfil_acessibilidade, "ambos", class: "peer sr-only", required: true, data: { profile_option: true } %>
        <%= form.label :perfil_acessibilidade_ambos, class: "bg-surface border-subtle flex min-h-20 cursor-pointer items-center gap-4 rounded-2xl border p-5", data: { profile_card: true } do %>
          <span class="bg-surface-muted text-accent flex h-12 w-12 items-center justify-center gap-2 rounded-full text-xl"><i class="fa-solid fa-book-open" aria-hidden="true"></i><i class="fa-solid fa-bullseye" aria-hidden="true"></i></span>
          <span>
            <span class="text-primary block text-base font-semibold">Tenho os dois</span>
            <span class="text-secondary mt-1 block text-sm leading-relaxed">Aplica todas as adaptações</span>
          </span>
        <% end %>
      </div>

      <div id="start-button-container" class="hidden pt-4">
        <%= form.submit "Começar", id: "start-button", disabled: true, class: "btn-primary min-h-12 w-full rounded-full px-6 py-3 text-base font-semibold cursor-pointer transition-colors disabled:cursor-not-allowed disabled:opacity-50" %>
      </div>
    <% end %>
  </div>
</div>

<script>
  const initializeProfileSelection = () => {
    const container = document.getElementById("start-button-container");
    const button = document.getElementById("start-button");
    const options = Array.from(document.querySelectorAll('[data-profile-option="true"]'));

    if (!container || !button || options.length === 0) return;

    const activeBackground = 'var(--action-primary-soft)';
    const activeBorder = 'var(--action-primary)';
    const inactiveBackground = 'var(--surface-bg)';
    const inactiveBorder = 'var(--border-subtle)';

    const syncButtonState = () => {
      let hasSelection = false;

      options.forEach((option) => {
        const card = document.querySelector(`label[for="${option.id}"]`);
        const selected = option.checked;

        if (selected) hasSelection = true;
        if (!card) return;

        if (selected) {
          card.style.borderColor = activeBorder;
          card.style.backgroundColor = activeBackground;
        } else {
          card.style.borderColor = inactiveBorder;
          card.style.backgroundColor = inactiveBackground;
        }
      });

      container.classList.toggle("hidden", !hasSelection);
      button.disabled = !hasSelection;
    };

    options.forEach((option) => {
      option.onchange = syncButtonState;
    });

    syncButtonState();
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initializeProfileSelection);
  } else {
    initializeProfileSelection();
  }

  document.addEventListener("turbo:load", initializeProfileSelection);
</script>
