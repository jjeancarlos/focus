<div class="min-h-screen flex flex-col items-center justify-center px-4 py-12"
     style="background-color: #F5F0E8;">

  <div class="mb-8 text-center">
    <h1 class="text-2xl font-bold text-[#2C4A7C]">Como você aprende?</h1>
    <p class="mt-3 text-base leading-relaxed text-[#7A726C]">
      Isso nos ajuda a adaptar sua experiência
    </p>
  </div>

  <div class="w-full max-w-md">

    <% if alert.present? %>
      <div class="mb-5 rounded-xl px-4 py-3 text-sm font-medium"
           style="background-color: #F5E9C8; color: #2A2520;">
        <%= alert %>
      </div>
    <% end %>

    <%= form_with model: @user, url: cadastro_perfil_path, method: :patch,
          local: true, id: "perfil-form" do |form| %>

      <%= form.hidden_field :perfil_acessibilidade, id: "perfil-input", value: "" %>

      <%# CARDS DE PERFIL %>
      <div class="space-y-4 mb-8">

        <%# DISLEXIA %>
        <div class="perfil-card rounded-2xl p-6 shadow-sm cursor-pointer
                    border-2 border-transparent"
             style="background-color: #EDE8DF;"
             data-perfil="dislexia"
             onclick="selecionarPerfil(this)">
          <div class="flex items-start gap-4">
            <span class="text-4xl">🔤</span>
            <div>
              <p class="text-lg font-semibold text-[#2C4A7C]">Tenho dislexia</p>
              <p class="text-sm mt-1 text-[#7A726C]">
                Adapta fonte, espaçamento e tempo de leitura
              </p>
            </div>
          </div>
        </div>

        <%# TDH %>
        <div class="perfil-card rounded-2xl p-6 shadow-sm cursor-pointer
                    border-2 border-transparent"
             style="background-color: #EDE8DF;"
             data-perfil="tdh"
             onclick="selecionarPerfil(this)">
          <div class="flex items-start gap-4">
            <span class="text-4xl">🎯</span>
            <div>
              <p class="text-lg font-semibold text-[#2C4A7C]">Tenho TDH</p>
              <p class="text-sm mt-1 text-[#7A726C]">
                Adapta temporizadores e foco visual
              </p>
            </div>
          </div>
        </div>

        <%# AMBOS %>
        <div class="perfil-card rounded-2xl p-6 shadow-sm cursor-pointer
                    border-2 border-transparent"
             style="background-color: #EDE8DF;"
             data-perfil="ambos"
             onclick="selecionarPerfil(this)">
          <div class="flex items-start gap-4">
            <span class="text-4xl">🔤🎯</span>
            <div>
              <p class="text-lg font-semibold text-[#2C4A7C]">Tenho os dois</p>
              <p class="text-sm mt-1 text-[#7A726C]">
                Aplica todas as adaptações
              </p>
            </div>
          </div>
        </div>

      </div>

      <%# BOTÃO — aparece só após selecionar %>
      <div id="btn-comecar" class="hidden">
        <%= form.submit "Começar 🚀",
              class: "min-h-12 w-full rounded-full bg-[#4A6FA5] px-6
                      py-3 text-base font-semibold text-white cursor-pointer" %>
      </div>

    <% end %>
  </div>
</div>

<script>
  function selecionarPerfil(card) {
    document.querySelectorAll('.perfil-card').forEach(function(c) {
      c.style.borderColor = 'transparent';
      c.style.backgroundColor = '#EDE8DF';
    });

    card.style.borderColor = '#4A6FA5';
    card.style.backgroundColor = '#D4E0F0';

    document.getElementById('perfil-input').value = card.dataset.perfil;
    document.getElementById('btn-comecar').classList.remove('hidden');
  }
</script>