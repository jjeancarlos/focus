<div class="min-h-screen flex flex-col items-center justify-center px-4 py-12"
     style="background-color: #F5F0E8;">

  <div class="mb-8 text-center">
    <h1 class="text-2xl font-bold text-[#2C4A7C]">Como você aprende?</h1>
    <p class="mt-3 text-base leading-relaxed text-[#7A726C]">
      Isso nos ajuda a adaptar sua experiência
    </p>
  </div>

  <div class="w-full max-w-md">
    <% if alert.present? || @user.errors.any? %>
      <div class="mb-5 rounded-2xl border border-[#e5ce94] bg-[#F5E9C8] px-4 py-3 text-base text-[#8a6510]">
        <p class="font-semibold"><%= alert.presence || t("auth.registration.profile_invalid") %></p>
      </div>
    <% end %>

    <%= form_with model: @user, url: cadastro_perfil_path, method: :patch, local: true, class: "space-y-4", data: { profile_form: true } do |form| %>
      <div>
        <%= form.radio_button :perfil_acessibilidade, "dislexia", class: "peer sr-only", required: true, data: { profile_option: true } %>
        <%= form.label :perfil_acessibilidade_dislexia, class: "flex min-h-20 cursor-pointer items-center gap-4 rounded-2xl border border-[#D9D0C4] bg-[#F5F0E8] p-5", data: { profile_card: true } do %>
          <span class="flex h-12 w-12 items-center justify-center rounded-full bg-[#D4E0F0] text-[#2C4A7C] text-2xl"><i class="fa-solid fa-book-open" aria-hidden="true"></i></span>
          <span>
            <span class="block text-base font-semibold text-stone-900">Tenho dislexia</span>
            <span class="mt-1 block text-sm leading-relaxed text-stone-600">Adapta fonte, espaçamento e tempo de leitura</span>
          </span>
        <% end %>
      </div>

      <div>
        <%= form.radio_button :perfil_acessibilidade, "tdh", class: "peer sr-only", required: true, data: { profile_option: true } %>
        <%= form.label :perfil_acessibilidade_tdh, class: "flex min-h-20 cursor-pointer items-center gap-4 rounded-2xl border border-[#D9D0C4] bg-[#F5F0E8] p-5", data: { profile_card: true } do %>
          <span class="flex h-12 w-12 items-center justify-center rounded-full bg-[#D4E0F0] text-[#2C4A7C] text-2xl"><i class="fa-solid fa-bullseye" aria-hidden="true"></i></span>
          <span>
            <span class="block text-base font-semibold text-stone-900">Tenho TDH</span>
            <span class="mt-1 block text-sm leading-relaxed text-stone-600">Adapta temporizadores e foco visual</span>
          </span>
        <% end %>
      </div>

      <div>
        <%= form.radio_button :perfil_acessibilidade, "ambos", class: "peer sr-only", required: true, data: { profile_option: true } %>
        <%= form.label :perfil_acessibilidade_ambos, class: "flex min-h-20 cursor-pointer items-center gap-4 rounded-2xl border border-[#D9D0C4] bg-[#F5F0E8] p-5", data: { profile_card: true } do %>
          <span class="flex h-12 w-12 items-center justify-center gap-2 rounded-full bg-[#D4E0F0] text-[#2C4A7C] text-xl"><i class="fa-solid fa-book-open" aria-hidden="true"></i><i class="fa-solid fa-bullseye" aria-hidden="true"></i></span>
          <span>
            <span class="block text-base font-semibold text-stone-900">Tenho os dois</span>
            <span class="mt-1 block text-sm leading-relaxed text-stone-600">Aplica todas as adaptações</span>
          </span>
        <% end %>
      </div>

      <div id="start-button-container" class="hidden pt-4">
        <%= form.submit "Começar", id: "start-button", disabled: true, class: "min-h-12 w-full rounded-full bg-[#4A6FA5] px-6 py-3 text-base font-semibold text-white disabled:cursor-not-allowed disabled:opacity-50 cursor-pointer" %>
      </div>
    <% end %>
  </div>
</div>

<script>
  const initializeProfileSelection = () => {
    const container = document.getElementById("start-button-container");
    const button = document.getElementById("start-button");
    const options = Array.from(document.querySelectorAll('[data-profile-option="true"]'));

    if (!container || !button || options.length === 0) return;

    const syncButtonState = () => {
      let hasSelection = false;

      options.forEach((option) => {
        const card = document.querySelector(`label[for="${option.id}"]`);
        const selected = option.checked;

        if (selected) hasSelection = true;
        if (!card) return;

        if (selected) {
          card.style.borderColor = "#4A6FA5";
          card.style.backgroundColor = "#D4E0F0";
        } else {
          card.style.borderColor = "#D9D0C4";
          card.style.backgroundColor = "#F5F0E8";
        }
      });

      container.classList.toggle("hidden", !hasSelection);
      button.disabled = !hasSelection;
    };

    options.forEach((option) => {
      option.onchange = syncButtonState;
    });

    syncButtonState();
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initializeProfileSelection);
  } else {
    initializeProfileSelection();
  }

  document.addEventListener("turbo:load", initializeProfileSelection);
</script>
