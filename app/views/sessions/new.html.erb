<div class="bg-app min-h-screen flex flex-col items-center justify-center px-4 py-12">
  <div class="mb-8 text-center">
    <%= image_tag "focus_logo1.png", alt: "Focus", class: "mx-auto h-30 w-auto" %>
    <p class="text-muted mt-3 text-base leading-relaxed">
      Tecnologia pensada para cada mente
    </p>
  </div>

  <div class="bg-surface shadow-soft w-full max-w-md rounded-2xl p-8">
    <%= form_with url: session_url, class: "space-y-5", local: true do |form| %>
      <%= hidden_field_tag :return_to, params[:return_to] %>

      <div>
        <%= form.label :email_address, "E-mail", class: "text-primary block text-base font-semibold" %>
        <%= form.email_field :email_address,
              required: true, autofocus: true,
              autocomplete: "username",
              value: params[:email_address],
              class: "form-input-theme mt-2 block min-h-12 w-full rounded-2xl px-4 py-3 text-base" %>
      </div>

      <div>
        <%= form.label :password, "Senha", class: "text-primary block text-base font-semibold" %>
        <%= form.password_field :password,
              required: true,
              autocomplete: "current-password",
              maxlength: 72,
              class: "form-input-theme mt-2 block min-h-12 w-full rounded-2xl px-4 py-3 text-base" %>
      </div>

      <div class="space-y-4 pt-2">
        <%= form.submit "Entrar",
              class: "btn-primary min-h-12 w-full rounded-full px-6 py-3 text-base font-semibold cursor-pointer transition-colors" %>
        <div class="text-center">
          <%= link_to "Criar conta", cadastro_path,
                class: "text-accent text-base font-semibold" %>
        </div>
      </div>
    <% end %>
  </div>
</div>
