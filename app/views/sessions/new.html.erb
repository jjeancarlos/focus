<div class="min-h-screen flex flex-col items-center justify-center px-4 py-12"
     style="background-color: #F5F0E8;">

  <div class="mb-8 text-center">
    <h1 class="text-4xl font-bold text-[#2C4A7C]">Focus</h1>
    <p class="mt-3 text-base leading-relaxed text-[#7A726C]">
      Transformando a Educação com Tecnologia e Inclusão
    </p>
  </div>

  <div class="w-full max-w-md rounded-2xl bg-[#EDE8DF] p-8 shadow-sm">

    <%# ALERT — mensagem de erro %>
    <% if alert.present? %>
      <div class="mb-5 rounded-xl px-4 py-3 text-sm font-medium"
           style="background-color: #F5E9C8; color: #2A2520;">
        <%= alert %>
      </div>
    <% end %>

    <%= form_with url: session_url, class: "space-y-5", local: true do |form| %>
      <%= hidden_field_tag :return_to, params[:return_to] %>

      <div>
        <%= form.label :email_address, "E-mail",
              class: "block text-base font-semibold text-stone-800" %>
        <%= form.email_field :email_address,
              required: true, autofocus: true,
              autocomplete: "username",
              value: params[:email_address],
              class: "mt-2 block min-h-12 w-full rounded-2xl border
                      border-[#D9D0C4] bg-[#F5F0E8] px-4 py-3 text-base
                      text-stone-900 outline-none focus:border-[#4A6FA5]
                      focus:ring-2 focus:ring-[#4A6FA5]/20" %>
      </div>

      <div>
        <%= form.label :password, "Senha",
              class: "block text-base font-semibold text-stone-800" %>
        <%= form.password_field :password,
              required: true,
              autocomplete: "current-password",
              maxlength: 72,
              class: "mt-2 block min-h-12 w-full rounded-2xl border
                      border-[#D9D0C4] bg-[#F5F0E8] px-4 py-3 text-base
                      text-stone-900 outline-none focus:border-[#4A6FA5]
                      focus:ring-2 focus:ring-[#4A6FA5]/20" %>
      </div>

      <div class="space-y-4 pt-2">
        <%= form.submit "Entrar",
              class: "min-h-12 w-full rounded-full bg-[#4A6FA5] px-6
                      py-3 text-base font-semibold text-white cursor-pointer" %>
        <div class="text-center">
          <%= link_to "Criar conta", cadastro_path,
                class: "text-base font-semibold text-[#4A6FA5]" %>
        </div>
      </div>
    <% end %>

  </div>
</div>