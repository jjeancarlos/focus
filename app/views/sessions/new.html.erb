<section class="mx-auto flex w-full max-w-md flex-col items-center justify-center py-6">
  <div class="mb-8 text-center">
    <h1 class="text-4xl font-bold text-[#2C4A7C]">Focus</h1>
    <p class="mt-3 text-base leading-relaxed text-[#7A726C]">
      Transformando a Educação com Tecnologia e Inclusão
    </p>
  </div>

  <div class="w-full rounded-2xl bg-[#EDE8DF] p-8 shadow-sm">
    <%= form_with url: session_url, class: "space-y-5" do |form| %>
      <div>
        <%= form.label :email_address, "E-mail", class: "block text-base font-semibold text-stone-800" %>
        <%= form.email_field :email_address, required: true, autofocus: true, autocomplete: "username", value: params[:email_address], class: "mt-2 block min-h-12 w-full rounded-2xl border border-[#D9D0C4] bg-[#F5F0E8] px-4 py-3 text-base text-stone-900 outline-none focus:border-[#4A6FA5] focus:ring-2 focus:ring-[#4A6FA5]/20" %>
      </div>

      <div>
        <%= form.label :password, "Senha", class: "block text-base font-semibold text-stone-800" %>
        <%= form.password_field :password, required: true, autocomplete: "current-password", maxlength: 72, class: "mt-2 block min-h-12 w-full rounded-2xl border border-[#D9D0C4] bg-[#F5F0E8] px-4 py-3 text-base text-stone-900 outline-none focus:border-[#4A6FA5] focus:ring-2 focus:ring-[#4A6FA5]/20" %>
      </div>

      <div class="space-y-4 pt-2">
        <%= form.submit "Entrar", class: "min-h-12 w-full rounded-full bg-[#4A6FA5] px-6 py-3 text-base font-semibold text-white" %>

        <div class="text-center">
          <%= link_to "Criar conta", "#", class: "text-base font-semibold text-[#4A6FA5]", aria: { disabled: true } %>
        </div>
      </div>
    <% end %>
  </div>
</section>
